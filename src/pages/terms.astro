---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Terms of Service — InkFlow" description="InkFlow terms of service." />
  <Navbar />

  <section class="pt-24 pb-20 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-gray-300">
      <h1 class="text-4xl font-extrabold text-white mb-8">Terms of Service</h1>
      <p class="text-sm text-gray-500">Last updated: June 2026</p>
      <div class="mt-8 space-y-4 text-sm">
        <p>By using InkFlow, you agree to these terms. If you do not agree, do not use the service.</p>
        <h2 class="text-lg font-semibold text-white mt-6">Account</h2>
        <p>You are responsible for maintaining your account security. You must provide accurate information when creating your account.</p>
        <h2 class="text-lg font-semibold text-white mt-6">Payment</h2>
        <p>Paid plans are billed monthly or annually. You can cancel anytime. Refunds are handled on a case-by-case basis.</p>
        <h2 class="text-lg font-semibold text-white mt-6">Limitation of Liability</h2>
        <p>InkFlow is provided "as is." We are not liable for damages arising from your use of the service, to the maximum extent permitted by law.</p>
      </div>
    </div>
  </section>
  <Footer />
</BaseLayout>
