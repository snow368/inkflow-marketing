---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import AftercareEmailGenerator from '../../components/AftercareEmailGenerator.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Aftercare Email Template Generator — Free" description="Generate professional tattoo aftercare emails for your clients. Free template generator. Copy and send in seconds." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Aftercare Email Generator</h1>
      <p class="mt-4 text-lg text-gray-400">Create a professional aftercare message for your clients. Just enter their name and tattoo type.</p>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <AftercareEmailGenerator />
    </div>
  </section>

  <Footer />
</BaseLayout>
