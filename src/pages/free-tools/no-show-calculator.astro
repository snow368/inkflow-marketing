---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import NoShowCalculator from '../../components/NoShowCalculator.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo No-Show Cost Calculator — Free Tool" description="Calculate how much no-shows cost your tattoo studio. Free interactive calculator. See your annual loss in seconds." />
  <!-- HowTo Schema -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": "How to Calculate No-Show Costs for Your Tattoo Studio",
    "description": "Use this calculator to estimate how much missed appointments cost your studio. Enter your average session price and no-show rate to see your annual loss.",
    "step": [
      { "@type": "HowToStep", "position": 1, "name": "Enter your average session price", "text": "Input the average price of a tattoo session at your studio." },
      { "@type": "HowToStep", "position": 2, "name": "Enter your weekly appointment count", "text": "Input how many appointments you book per week." },
      { "@type": "HowToStep", "position": 3, "name": "Enter your no-show rate", "text": "Input your estimated no-show percentage. Industry average is 10-30%." },
      { "@type": "HowToStep", "position": 4, "name": "View your annual loss", "text": "The calculator shows your estimated annual revenue lost to no-shows and potential savings." }
    ]
  })} />
  <FAQSchema questions={[
    { question: "Is the no-show calculator free?", answer: "Yes. Calculate unlimited scenarios for free. No account or signup required." },
    { question: "How accurate is the estimate?", answer: "The estimate is based on your inputs. For best results, use your actual no-show rate from booking records rather than guessing." },
    { question: "What's the average no-show rate for tattoo studios?", answer: "Industry data shows most studios lose 10-30% of booked appointments to no-shows." },
    { question: "How can I reduce no-shows?", answer: "InkFlow's deposit-based booking system cuts no-shows by up to 80%. Automated reminders and waitlists help recover last-minute cancellations." },
  ]} />
  <Navbar />

  <!-- Hero -->
  <section class="pt-24 pb-12 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo No-Show Cost Calculator</h1>
      <p class="mt-4 text-lg text-gray-400">See exactly how much missed appointments cost your studio each year — and how much you could save.</p>
    </div>
  </section>

  <!-- Calculator -->
  <section class="pb-12">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <NoShowCalculator />
    </div>
  </section>

  <!-- Social Proof -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto flex max-w-3xl flex-wrap items-center justify-center gap-6 px-4 text-sm text-gray-500 sm:px-6 lg:px-8">
      <span>Trusted by 500+ studios</span>
      <span class="text-gray-700">|</span>
      <span>G2 Rating 4.8/5</span>
      <span class="text-gray-700">|</span>
      <span>Avg 80% no-show reduction</span>
    </div>
  </section>

  <!-- What's Next -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-white">Know your number. Now do something about it.</h2>
      <p class="mt-3 text-gray-400">InkFlow's booking system cuts no-shows by up to 80% with automated deposits, reminders, and waitlists — built into one platform.</p>
    </div>
    <div class="mx-auto mt-10 grid max-w-4xl gap-6 px-4 sm:grid-cols-3 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5 text-center">
        <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-accent-500/10 text-accent-400 text-lg font-bold">1</div>
        <h3 class="text-sm font-semibold text-white">Calculate Your Loss</h3>
        <p class="mt-1 text-xs text-gray-400">You just saw how much no-shows cost.</p>
      </div>
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5 text-center">
        <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-accent-500/10 text-accent-400 text-lg font-bold">2</div>
        <h3 class="text-sm font-semibold text-white">Try InkFlow Free</h3>
        <p class="mt-1 text-xs text-gray-400">Set up deposits & automated reminders in minutes.</p>
      </div>
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5 text-center">
        <div class="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-lg bg-accent-500/10 text-accent-400 text-lg font-bold">3</div>
        <h3 class="text-sm font-semibold text-white">Cut No-Shows by 80%</h3>
        <p class="mt-1 text-xs text-gray-400">Automated system works while you tattoo.</p>
      </div>
    </div>
  </section>

  <!-- Free vs Paid -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-center text-2xl font-bold text-white">Free Tool vs Full Platform</h2>
      <div class="overflow-hidden rounded-xl border border-ink-800">
        <table class="w-full text-sm">
          <thead><tr class="border-b border-ink-800 bg-ink-900/50">
            <th class="px-5 py-3 text-left text-gray-300"></th>
            <th class="px-5 py-3 text-center text-gray-500">This Calculator</th>
            <th class="px-5 py-3 text-center text-accent-400">InkFlow Free</th>
          </tr></thead>
          <tbody class="divide-y divide-ink-800">
            <tr><td class="px-5 py-3 text-gray-400">See no-show costs</td><td class="px-5 py-3 text-center text-gray-500">✅</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
            <tr><td class="px-5 py-3 text-gray-400">Auto-collect deposits</td><td class="px-5 py-3 text-center text-gray-500">❌</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
            <tr><td class="px-5 py-3 text-gray-400">SMS/email reminders</td><td class="px-5 py-3 text-center text-gray-500">❌</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
            <tr><td class="px-5 py-3 text-gray-400">Waitlist management</td><td class="px-5 py-3 text-center text-gray-500">❌</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
            <tr><td class="px-5 py-3 text-gray-400">Track actual no-shows</td><td class="px-5 py-3 text-center text-gray-500">❌</td><td class="px-5 py-3 text-center text-accent-400">✅</td></tr>
          </tbody>
        </table>
      </div>
      <div class="mt-8 text-center">
        <a href="https://app.ink-flows.com/register" class="inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">
          Start Free Trial — No Credit Card
        </a>
        <p class="mt-2 text-sm text-gray-500">Join 500+ studios already using InkFlow</p>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
