---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import FreeWaiverGenerator from '../../components/FreeWaiverGenerator.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Free Tattoo Consent Form Generator — Digital Waiver Template" description="Generate a free tattoo consent form for your studio. Digital waiver template with e-signature fields. Export as PDF. No signup required." />
  <FAQSchema questions={[
    { question: "Is the consent form generator really free?", answer: "Yes. Generate unlimited consent forms for free. No account or signup required." },
    { question: "Are the generated waivers legally binding?", answer: "The generated template includes standard waiver language, but we recommend having a lawyer review it for your specific jurisdiction." },
    { question: "Can I customize the waiver template?", answer: "Yes. The generator includes editable fields for studio name, address, services, and medical disclaimer text." },
    { question: "How do I collect signatures on the generated form?", answer: "Print the generated form for in-person signing, or use InkFlow's digital waiver system for e-signatures." },
  ]} />
  <Navbar />

  <section class="pt-24 pb-12 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">FREE TOOL</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Free Tattoo Consent Form Generator</h1>
      <p class="mt-4 text-lg text-gray-400">Generate a professional tattoo consent form for your studio. Customize fields, add your studio info, and print or export as PDF.</p>
    </div>
  </section>

  <section class="pb-12">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <FreeWaiverGenerator />
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-white">What Your Consent Form Should Include</h2>
      <p class="mt-3 text-gray-400">A proper tattoo consent form protects both you and your client.</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-3 text-left">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-4"><h3 class="text-sm font-semibold text-white">Client Information</h3><p class="mt-1 text-xs text-gray-400">Full name, date of birth, ID verification, and emergency contact. Required for legal documentation.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-4"><h3 class="text-sm font-semibold text-white">Medical Disclosure</h3><p class="mt-1 text-xs text-gray-400">Allergies, medications, skin conditions, blood-borne diseases, and pregnancy status. Critical for client safety.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-4"><h3 class="text-sm font-semibold text-white">Liability &amp; Consent</h3><p class="mt-1 text-xs text-gray-400">Acknowledgment of risks, aftercare agreement, photo release, and minor consent if applicable. Must be signed and dated.</p></div>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16 text-center">
    <h2 class="text-2xl font-bold text-white">Go Fully Digital — No Paper, No Lost Forms</h2>
    <p class="mt-3 text-gray-400">InkFlow's digital waivers include QR check-in, e-signatures, and cloud storage. Clients sign on their phone — legally binding, always accessible.</p>
    <a href="/features/tattoo-waiver-software" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Learn More →</a>
  </section>
  <Footer />
</BaseLayout>
