---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FreeWaiverGenerator from '../../components/FreeWaiverGenerator.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Free Tattoo Consent Form Generator — Online Waiver | InkFlow" description="Generate a free tattoo consent form online. No sign-up required. E-signature, health declaration, and PDF download." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Free Tattoo Consent Form Generator</h1>
      <p class="mt-4 text-lg text-gray-400">Create a legally binding tattoo waiver in seconds. Fill out, sign, and print. No account needed.</p>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <FreeWaiverGenerator />
    </div>
  </section>

  <Footer />
</BaseLayout>
