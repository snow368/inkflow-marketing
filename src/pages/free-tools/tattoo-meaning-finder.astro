---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQSchema from '../../components/FAQSchema.astro';
import TattooMeaningFinder from '../../components/TattooMeaningFinder.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Meaning Finder — Free Symbolism &amp; Design Guide" description="Discover the meaning behind popular tattoo symbols and designs. Free tattoo meaning finder tool. Search by symbol, style, or culture." />
  <FAQSchema questions={[
    { question: "Is the tattoo meaning finder free?", answer: "Yes. Search unlimited tattoo meanings for free. No account or signup required." },
    { question: "What symbols are included?", answer: "Hundreds of symbols across categories: animals, flowers, mythological, geometric, religious, cultural, and modern designs." },
    { question: "Can I suggest a meaning to add?", answer: "Yes. Contact us with your suggestion and source. We review and add new meanings regularly." },
  ]} />
  <Navbar />

  <section class="pt-24 pb-12 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">FREE TOOL</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Meaning Finder</h1>
      <p class="mt-4 text-lg text-gray-400">Discover the meaning behind popular tattoo symbols and designs. Search by symbol, style, or cultural tradition.</p>
    </div>
  </section>

  <section class="pb-12">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <TattooMeaningFinder />
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-white">Popular Tattoo Meanings Clients Ask About</h2>
      <p class="mt-3 text-gray-400">Help your clients choose designs with meaning. These are the most searched symbols.</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-3 text-left">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-4"><h3 class="text-sm font-semibold text-white">Lotus Flower</h3><p class="mt-1 text-xs text-gray-400">Symbolizes rebirth, enlightenment, and overcoming adversity. Popular in Buddhist and Hindu traditions.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-4"><h3 class="text-sm font-semibold text-white">Wolf</h3><p class="mt-1 text-xs text-gray-400">Represents loyalty, family, protection, and instinct. A symbol of strength and pack mentality.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-4"><h3 class="text-sm font-semibold text-white">Compass</h3><p class="mt-1 text-xs text-gray-400">Guides the way, represents direction, travel, and finding one's purpose. Often combined with maps or coordinates.</p></div>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16 text-center">
    <h2 class="text-2xl font-bold text-white">Help Clients Find Their Perfect Design</h2>
    <p class="mt-3 text-gray-400">InkFlow helps you manage consultations, design approvals, and bookings — all in one platform.</p>
    <a href="/features/tattoo-booking-software" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Learn More →</a>
  </section>
  <Footer />
</BaseLayout>
