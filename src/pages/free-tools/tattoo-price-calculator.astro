---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import TattooPriceCalculator from '../../components/TattooPriceCalculator.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Price Calculator — Free Cost Estimator" description="Estimate the cost of your next tattoo. Free interactive calculator based on size, detail, and placement." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Price Calculator</h1>
      <p class="mt-4 text-lg text-gray-400">Get a ballpark estimate for your next tattoo. Choose your size, detail, and placement.</p>
    </div>
  </section>

  <section class="pb-20">
    <div class="mx-auto max-w-xl px-4 sm:px-6 lg:px-8">
      <TattooPriceCalculator />
    </div>
  </section>

  <Footer />
</BaseLayout>
