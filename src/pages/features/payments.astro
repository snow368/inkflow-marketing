---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Payment Processing & Deposit Software — InkFlow" description="Tattoo payment processing built for studios. Collect deposits at booking, send payment links, split commissions automatically. Stripe-powered. No POS hardware needed." />
  <Navbar />

  <!-- HERO -->
  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold text-accent-400 mb-3">TATTOO PAYMENT PROCESSING</p>
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Get Paid Faster. Track Every Dollar.</h1>
        <p class="mt-6 text-lg text-gray-400">Deposits at booking, payment links after sessions, automatic commission splitting — all in one system. No separate POS terminal needed.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="https://app.ink-flows.com/register" class="inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
          <a href="/pricing" class="inline-block rounded-lg border border-ink-700 px-8 py-3.5 text-base font-semibold text-white hover:bg-ink-800 transition-all">See Pricing</a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div><p class="text-3xl font-bold text-accent-400">2.9%+$0.30</p><p class="mt-1 text-sm text-gray-500">Standard card processing</p></div>
        <div><p class="text-3xl font-bold text-accent-400">$0</p><p class="mt-1 text-sm text-gray-500">Platform fee on payments</p></div>
        <div><p class="text-3xl font-bold text-accent-400">Auto</p><p class="mt-1 text-sm text-gray-500">Commission calculations</p></div>
        <div><p class="text-3xl font-bold text-accent-400">No HW</p><p class="mt-1 text-sm text-gray-500">Works with phone or tablet</p></div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Tattoo Payment Processing Is Different</h2>
      <div class="mt-8 space-y-4">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><p class="text-gray-400"><strong class="text-white">💸 "I need deposits at booking, not cards on file"</strong> — Most processors only offer card-on-file. InkFlow collects real deposits that lock appointments and improve cash flow.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><p class="text-gray-400"><strong class="text-white">🧮 "Commission math takes hours"</strong> — Spreadsheets, calculators, late-night emails. InkFlow auto-splits commissions per artist after every appointment.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><p class="text-gray-400"><strong class="text-white">📱 "I don't want to buy a POS terminal"</strong> — Payment links sent via SMS. Clients pay with Apple Pay or card on their phone. No Square reader, no Clover terminal.</p></div>
      </div>
    </div>
  </section>

  <!-- FEATURES KEEP EXISTING SECTIONS but with some MOFU context -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-12">

      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div>
          <h2 class="text-2xl font-bold text-white">Deposit Collection</h2>
          <p class="mt-4 text-gray-400">Require a deposit at booking to secure appointments. Set flat fees or percentages. Deposits are tracked as liabilities until the service is completed — no accounting headaches.</p>
          <p class="mt-3 text-sm text-gray-500">→ Unlike Square: InkFlow collects <strong class="text-white">actual payments</strong> at booking, not card-on-file holds.</p>
        </div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/50 p-8 text-center">
          <p class="mt-4 text-3xl font-bold text-white">$0</p>
          <p class="text-sm text-gray-500">Stripe processing fee only — no platform markup</p>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div class="order-2 md:order-1 rounded-xl border border-ink-800 bg-ink-900/50 p-8 text-center">
          <span class="text-4xl">🔗</span>
          <p class="mt-4 text-sm text-gray-400">Send a payment link via SMS right after the session.</p>
        </div>
        <div class="order-1 md:order-2">
          <h2 class="text-2xl font-bold text-white">Payment Links — No Terminal Needed</h2>
          <p class="mt-4 text-gray-400">After a session, send a payment link via SMS or email. Clients pay with credit card, Apple Pay, or Google Pay — no terminal. Works for balance collection, tips, and retail sales.</p>
          <p class="mt-3 text-sm text-gray-500">→ InkFlow works as a <strong class="text-white">tattoo POS system</strong> without buying POS hardware.</p>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div>
          <h2 class="text-2xl font-bold text-white">Automatic Commission Splitting</h2>
          <p class="mt-4 text-gray-400">Set different commission rates per artist. InkFlow auto-calculates payouts after each appointment. No more spreadsheet math or awkward conversations.</p>
          <p class="mt-3 text-sm text-gray-500">→ Unlike Vagaro: InkFlow's <strong class="text-white">tattoo commission software</strong> is built-in, no manual entry.</p>
        </div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/50 p-8 text-center">
          <span class="text-4xl">📊</span>
          <p class="mt-4 text-sm text-gray-400">Auto-calculated per artist, per appointment</p>
        </div>
      </div>

    </div>
  </section>

  <!-- COMPARISON -->
  <section class="border-t border-ink-800/50 py-16 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">InkFlow vs Other Payment Solutions</h2>
      <div class="mt-8 space-y-3">
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">Vs Square → Booking + payments in one</p><p class="text-sm text-gray-400">Square is a payment system with basic booking. InkFlow is studio management with integrated payments.</p></div></div>
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">Vs Stripe → No code needed</p><p class="text-sm text-gray-400">Stripe requires setup. InkFlow's Stripe integration works out of the box — deposits, payments, refunds.</p></div></div>
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">Vs Lightspeed → Purpose-built for tattoo</p><p class="text-sm text-gray-400">Lightspeed is retail POS adapted for tattoo. InkFlow understands deposits, commissions, and waivers.</p></div></div>
      </div>
    </div>
  </section>

  <!-- STAY AS CTA -->
  <section class="py-16 text-center border-t border-ink-800/50">
    <h2 class="text-2xl font-bold text-white">Start Collecting Deposits Today</h2>
    <p class="mt-2 text-gray-400">Free plan includes deposit collection, payment links, and commission tracking.</p>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Start Free →</a>
  </section>
  <Footer />
</BaseLayout>
