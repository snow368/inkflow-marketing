---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Shop Inventory Management Software — InkFlow" description="Track ink, needles, and supplies with low-stock alerts and cost-per-session tracking. Never run out of what you need." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Shop Inventory Management</h1>
      <p class="mt-6 text-lg text-gray-400">Keep track of your supplies — ink, needles, cartridges, and aftercare products. Get low-stock alerts before you run out.</p>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-8">
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
        <h3 class="text-lg font-semibold text-white">Real-Time Stock Tracking</h3>
        <p class="mt-2 text-sm text-gray-400">Track every item — from ink bottles to needle cartridges. Know exactly what you have, what's running low, and what needs reordering.</p>
      </div>
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
        <h3 class="text-lg font-semibold text-white">Cost Per Session</h3>
        <p class="mt-2 text-sm text-gray-400">See exactly how much each appointment costs in supplies. Know your margins on every job.</p>
      </div>
    </div>
  </section>

  <section class="py-16 text-center border-t border-ink-800/50">
    <h2 class="text-2xl font-bold text-white">Try InkFlow Free</h2>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Start Free Trial</a>
  </section>
  <Footer />
</BaseLayout>
