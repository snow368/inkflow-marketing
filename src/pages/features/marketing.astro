---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Review Management & Marketing Automation | InkFlow" description="Automate review requests, referral programs, and lead capture for your tattoo studio. Built into your management platform — no separate tools needed." />
  <Navbar />

  <!-- HERO -->
  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-accent-400 mb-3">TATTOO MARKETING AUTOMATION</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Turn Every Client Into Your Best Marketer</h1>
      <p class="mt-6 text-lg text-gray-400">Automated review requests after each session. Referral tracking that rewards your best clients. Lead capture from your booking page. All built into InkFlow — no Mailchimp, no separate tools.</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="https://app.ink-flows.com/register" class="inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-12">
      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div>
          <h2 class="text-2xl font-bold text-white">Auto Review Requests</h2>
          <p class="mt-4 text-gray-400">Send review requests automatically after each appointment — timed to arrive when the client's experience is freshest. Boost your Google Business Profile and Yelp presence without manual follow-ups.</p>
          <p class="mt-3 text-sm text-gray-500">→ <strong class="text-white">Tattoo review management software</strong> built into your daily workflow.</p>
        </div>
        <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
          <p class="text-sm text-gray-500">[Screenshot: Review request settings]</p>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div class="order-2 md:order-1 rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
          <p class="text-sm text-gray-500">[Screenshot: Referral tracking]</p>
        </div>
        <div class="order-1 md:order-2">
          <h2 class="text-2xl font-bold text-white">Referral Program Automation</h2>
          <p class="mt-4 text-gray-400">See which clients refer the most business. Reward them automatically. Referral clients book at higher rates and become loyal faster — track every referral in the system.</p>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div>
          <h2 class="text-2xl font-bold text-white">Lead Capture from Booking</h2>
          <p class="mt-4 text-gray-400">Every booking request captures lead info — name, email, phone, tattoo description. Follow up automatically. <strong class="text-white">Tattoo lead management software</strong> that works while you sleep.</p>
        </div>
        <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
          <p class="text-sm text-gray-500">[Screenshot: Lead inbox]</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 text-center border-t border-ink-800/50">
    <h2 class="text-2xl font-bold text-white">Automate Your Studio's Marketing</h2>
    <p class="mt-2 text-gray-400">Free plan includes review requests and referral tracking.</p>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Start Free →</a>
  </section>
  <Footer />
</BaseLayout>
