---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Studio Health Compliance Software — InkFlow" description="Stay compliant with health department checklists, autoclave logs, and inspection prep. Built into InkFlow." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Health Compliance for Tattoo Studios</h1>
      <p class="mt-6 text-lg text-gray-400">Health inspections don't have to be stressful. InkFlow helps you stay compliant with built-in checklists, autoclave logs, and documentation.</p>
    </div>
  </section>

  <section class="py-16 text-center border-t border-ink-800/50">
    <h2 class="text-2xl font-bold text-white">Stay Compliant</h2>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free</a>
  </section>
  <Footer />
</BaseLayout>
