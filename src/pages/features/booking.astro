---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Booking Software — Stop No-Shows, Fill Your Calendar | InkFlow" description="Tattoo booking software built for studios. Deposit-based scheduling cuts no-shows by 80%. Multi-artist calendar, automated reminders, online booking widget. Start free." />
  <Navbar />

  <!-- HERO: Problem-first, not product-first -->
  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <p class="text-sm font-semibold text-accent-400 mb-3">TATTOO BOOKING SOFTWARE</p>
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Stop Losing 30% of Revenue to No-Shows</h1>
        <p class="mt-6 text-lg text-gray-400">Every no-show costs you time and money. InkFlow's deposit-based booking software locks in commitment at the time of booking — so your calendar stays full and your artists stay paid.</p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="https://app.ink-flows.com/register" class="inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
          <a href="/compare/best-tattoo-studio-software" class="inline-block rounded-lg border border-ink-700 px-8 py-3.5 text-base font-semibold text-white hover:bg-ink-800 transition-all">See How We Compare</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SOCIAL PROOF: Stats that matter to buyers -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div><p class="text-3xl font-bold text-accent-400">80%</p><p class="mt-1 text-sm text-gray-500">Fewer no-shows with deposits</p></div>
        <div><p class="text-3xl font-bold text-accent-400">30s</p><p class="mt-1 text-sm text-gray-500">Client booking time</p></div>
        <div><p class="text-3xl font-bold text-accent-400">98%</p><p class="mt-1 text-sm text-gray-500">SMS reminder open rate</p></div>
        <div><p class="text-3xl font-bold text-accent-400">24/7</p><p class="mt-1 text-sm text-gray-500">Online bookings without phone tag</p></div>
      </div>
    </div>
  </section>

  <!-- THE PROBLEM: Why general booking tools don't work for tattoo studios -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Why General Booking Software Falls Short</h2>
      <div class="mt-8 space-y-4">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><p class="text-gray-400"><strong class="text-white">❌ No deposit collection:</strong> Acuity, Calendly, and Square let clients book without commitment. No-shows still happen.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><p class="text-gray-400"><strong class="text-white">❌ Not tattoo-specific:</strong> Salon software doesn't understand deposit policies, multi-artist commission splits, or consent form workflows.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><p class="text-gray-400"><strong class="text-white">❌ Fragmented tools:</strong> One app for booking, another for waivers, another for payments. Your team juggles 3 logins.</p></div>
      </div>
    </div>
  </section>

  <!-- SOLUTION: Features as problem-solvers -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">How InkFlow Fixes Booking — Built for Tattoo Studios</h2>
      <div class="mt-12 space-y-16">
        <div class="grid gap-8 md:grid-cols-2 items-center">
          <div>
            <h3 class="text-2xl font-bold text-white">Deposit-Required Scheduling</h3>
            <p class="mt-4 text-gray-400">Clients pay a deposit to book. No credit card form — actual payment. No-shows drop by 80% because there's skin in the game. Set flat fees or percentages per service, per artist, or globally. Refunds auto-process based on your cancellation policy.</p>
            <p class="mt-3 text-sm text-gray-500">→ Compared to Booksy: InkFlow collects deposits at booking, not just card-on-file. Your cash flow improves immediately.</p>
          </div>
          <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
            <p class="text-sm text-gray-500">[Screenshot: Deposit settings]</p>
          </div>
        </div>

        <div class="grid gap-8 md:grid-cols-2 items-center">
          <div class="order-2 md:order-1 rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
            <p class="text-sm text-gray-500">[Screenshot: Reminder templates]</p>
          </div>
          <div class="order-1 md:order-2">
            <h3 class="text-2xl font-bold text-white">Automated Reminders That Actually Work</h3>
            <p class="mt-4 text-gray-400">SMS (98% open rate) and email reminders fire at 48h, 24h, and 1h before each appointment. Clients confirm, reschedule, or cancel — all in one tap. Customize templates to match your studio's voice.</p>
            <p class="mt-3 text-sm text-gray-500">→ Unlike Vagaro: InkFlow sends SMS at no extra cost per message.</p>
          </div>
        </div>

        <div class="grid gap-8 md:grid-cols-2 items-center">
          <div>
            <h3 class="text-2xl font-bold text-white">Multi-Artist Calendar</h3>
            <p class="mt-4 text-gray-400">See every artist's schedule at a glance. Color-coded, drag-and-drop to reschedule. Block breaks, walk-ins, guest artists. Each artist gets their own booking link — clients book directly with who they want.</p>
          </div>
          <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
            <p class="text-sm text-gray-500">[Screenshot: Calendar view]</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- BUYER'S GUIDE: What to look for in booking software -->
  <section class="border-t border-ink-800/50 py-16 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">What to Look For in Tattoo Booking Software</h2>
      <p class="mt-3 text-center text-gray-500">Before you decide, make sure your booking software checks these boxes:</p>
      <div class="mt-8 space-y-4">
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">Deposit collection at booking</p><p class="text-sm text-gray-400">Not "card on file" — actual payment that locks the appointment.</p></div></div>
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">Multi-artist support</p><p class="text-sm text-gray-400">Separate calendars, booking links, and commission rules per artist.</p></div></div>
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">Integrated waivers & payments</p><p class="text-sm text-gray-400">One platform for booking, consent forms, and checkout — not three.</p></div></div>
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">No hidden message fees</p><p class="text-sm text-gray-400">SMS reminders included, not $0.07 per text.</p></div></div>
      </div>
    </div>
  </section>

  <!-- FAQ: Evaluation-stage concerns -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-8 text-2xl font-bold text-white text-center">Frequently Asked Questions</h2>
      <div class="space-y-4">
        <details class="rounded-xl border border-ink-800 p-4">
          <summary class="cursor-pointer text-sm font-medium text-white">Can clients book online without creating an account?</summary>
          <p class="mt-2 text-sm text-gray-400">Yes. Clients book via a public link — no account needed. They just provide name, email, and phone. Returning clients are recognized automatically.</p>
        </details>
        <details class="rounded-xl border border-ink-800 p-4">
          <summary class="cursor-pointer text-sm font-medium text-white">Can I set different deposits for different services?</summary>
          <p class="mt-2 text-sm text-gray-400">Absolutely. Per-service, per-artist, or global default. Percentage or flat fee. Refund policies are automatic based on your rules.</p>
        </details>
        <details class="rounded-xl border border-ink-800 p-4">
          <summary class="cursor-pointer text-sm font-medium text-white">How does InkFlow compare to Acuity or Booksy?</summary>
          <p class="mt-2 text-sm text-gray-400">InkFlow is built for tattoo studios. Acuity and Booksy are general-purpose. InkFlow includes tattoo-specific features: digital consent forms, commission splitting, aftercare automation, and inventory tracking — all in one platform. <a href="/compare/best-tattoo-studio-software" class="text-accent-400 hover:underline">See full comparison →</a></p>
        </details>
        <details class="rounded-xl border border-ink-800 p-4">
          <summary class="cursor-pointer text-sm font-medium text-white">Does the booking widget work on my existing website?</summary>
          <p class="mt-2 text-sm text-gray-400">Yes. One line of code embeds a booking button on any site — Squarespace, Wix, WordPress, or custom.</p>
        </details>
        <details class="rounded-xl border border-ink-800 p-4">
          <summary class="cursor-pointer text-sm font-medium text-white">Can I migrate from another booking system?</summary>
          <p class="mt-2 text-sm text-gray-400">Yes. We help you import client data, artist schedules, and service menus. Most studios are set up in under an hour.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-ink-800/50 py-16 text-center">
    <h2 class="text-2xl font-bold text-white">Ready to Fill Your Calendar and Cut No-Shows?</h2>
    <p class="mt-3 text-gray-400">Start free. No credit card required. Set up in 5 minutes.</p>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
    <p class="mt-3 text-sm text-gray-600">Also available: <a href="/pricing" class="text-accent-400 hover:underline">Compare plans</a> · <a href="/compare/best-tattoo-studio-software" class="text-accent-400 hover:underline">See vs alternatives</a></p>
  </section>

  <Footer />
</BaseLayout>
