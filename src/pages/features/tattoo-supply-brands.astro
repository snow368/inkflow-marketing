---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import FAQSchema from '../../components/FAQSchema.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Supply Brands Directory — Find &amp; Compare Suppliers" description="Discover and compare tattoo supply brands. See what other studios use, read reviews, and find your next supplier. Ink, needles, cartridges, machines, and aftercare." />
  <FAQSchema questions={[
    { question: "What types of supply brands are listed?", answer: "Ink brands, needle and cartridge manufacturers, tattoo machines, aftercare products, PPE, and studio equipment. Updated regularly." },
    { question: "Can I leave reviews for supply brands?", answer: "Yes. Share your experience with specific brands and products. Help other studio owners make informed purchasing decisions." },
    { question: "Are prices listed for supplies?", answer: "Where available, we list estimated retail prices. Actual pricing varies by distributor. Links to official distributors are provided." },
  ]} />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-accent-400 mb-3">TATTOO SUPPLY BRANDS</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Supply Brands Directory: Find &amp; Compare Suppliers</h1>
      <p class="mt-6 text-lg text-gray-400">Discover and compare tattoo supply brands — ink, needles, cartridges, machines, and aftercare. Read reviews from other studio owners and find your next supplier.</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="https://app.ink-flows.com/register" class="inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Why a Supply Brands Directory Helps Your Studio</h2>
      <div class="mt-8 space-y-4">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Finding reliable suppliers takes hours of research.</h3><p class="mt-1 text-sm text-gray-400">The InkFlow directory consolidates verified suppliers. See what other tattoo studios use and trust before you buy.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Quality varies wildly between brands — reviews help you choose.</h3><p class="mt-1 text-sm text-gray-400">Read honest reviews from studio owners who've tested the products. No sponsored content, just real opinions.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">You might be paying more than you need to.</h3><p class="mt-1 text-sm text-gray-400">Compare prices across brands and find the best value for your studio's needs. Save money without sacrificing quality.</p></div>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Directory Features</h2>
      <div class="mt-12 space-y-16">
      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div>
          <h3 class="text-2xl font-bold text-white">Curated Brand Directory with Reviews</h3>
          <p class="mt-4 text-gray-400">Browse brands by category — ink, needles, machines, aftercare, PPE, and studio equipment. Read and leave reviews.</p>
          <h4 class="mt-4 text-lg font-semibold text-white">Category-Based Browsing</h4>
          <p class="text-sm text-gray-400">Find exactly what you need. Filter by product type, price range, and rating. Compare similar products side by side.</p>
          <h5 class="mt-3 text-base font-medium text-white">Verified Purchase Reviews</h5>
          <p class="text-sm text-gray-400">Reviews are tagged with verification status. Know which reviews come from actual buyers vs anonymous opinions.</p>
        </div>
        <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
          <p class="text-sm text-gray-400">[Screenshot: Brand directory]</p>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div class="order-2 md:order-1 rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
          <p class="text-sm text-gray-400">[Screenshot: Price comparison]</p>
        </div>
        <div class="order-1 md:order-2">
          <h3 class="text-2xl font-bold text-white">Price Comparison &amp; Distributor Links</h3>
          <p class="mt-4 text-gray-400">Compare estimated retail prices across brands. Direct links to official distributors for purchasing.</p>
          <h4 class="mt-4 text-lg font-semibold text-white">Distributor Network</h4>
          <p class="text-sm text-gray-400">Find authorized distributors for each brand. Compare shipping costs and delivery times. Some distributors offer InkFlow-exclusive discounts.</p>
          <h5 class="mt-3 text-base font-medium text-white">Price History Tracking</h5>
          <p class="text-sm text-gray-400">See price trends over time. Know when to buy and when to wait for a better deal.</p>
        </div>
      </div>
    </div>
    </div>
  </section>

  <!-- BUYER GUIDE -->
  <section class="border-t border-ink-800/50 py-16 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">How to Choose a Supply Brand</h2>
      <p class="mt-3 text-center text-gray-400">The best brand depends on your budget, quality requirements, and preferred suppliers.</p>
      <div class="mt-8 space-y-4">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Budget-conscious studio</h3><p class="text-sm text-gray-400 mt-1">Compare prices across brands using InkFlow's directory. Find quality supplies at the best value. Read reviews from studios with similar needs.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Premium studio focused on quality</h3><p class="text-sm text-gray-400 mt-1">Discover top-rated brands reviewed by other tattoo artists. Filter by rating, category, and price range to find your perfect supplier.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><h3 class="text-white font-semibold text-sm">Multi-location bulk buyer</h3><p class="text-sm text-gray-400 mt-1">Find distributors that offer volume pricing. Compare bulk rates across suppliers and save on per-unit costs for high-usage items.</p></div>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16 text-center">
    <h2 class="text-2xl font-bold text-white">Find Your Next Supplier</h2>
    <p class="mt-3 text-gray-400">Free plan includes full access to the supply brands directory.</p>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
  </section>
  <Footer />
</BaseLayout>
