---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Studio Competitor Tracking — InkFlow" description="Track competitor studios, compare pricing, and spot market trends — built into your management platform." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Competitor Intelligence for Tattoo Studios</h1>
      <p class="mt-6 text-lg text-gray-400">Track what other studios in your area are doing. Compare pricing, services, and marketing — all from your InkFlow dashboard.</p>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-8">
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
        <h2 class="text-xl font-bold text-white">Track Local Competitors</h2>
        <p class="mt-2 text-gray-400">Add competitor studios to your dashboard. See their pricing, services, and featured artists — all in one place.</p>
      </div>
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-6">
        <h2 class="text-xl font-bold text-white">Market Intelligence</h2>
        <p class="mt-2 text-gray-400">Spot trends before they pass you by. See what services other studios are adding, what prices are doing in your area.</p>
      </div>
    </div>
  </section>

  <section class="py-16 text-center border-t border-ink-800/50">
    <h2 class="text-2xl font-bold text-white">Know Your Market</h2>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free</a>
  </section>
  <Footer />
</BaseLayout>
