---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Aftercare Automation — InkFlow" description="Automate tattoo aftercare with healing check-ins at day 3, 7, and 14. Studios see 40% more healed photo submissions. Set it once, runs on autopilot." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Aftercare Automation</h1>
      <p class="mt-6 text-lg text-gray-400">Automated healing check-ins, healed photo requests, and review prompts — sent at the right time, every time.</p>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 space-y-16">
      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div>
          <h2 class="text-2xl font-bold text-white">Automated Healing Check-Ins</h2>
          <p class="mt-4 text-gray-400">Send aftercare instructions automatically after each session. Follow up at day 3, day 7, and day 14 to check healing progress. Clients feel cared for, and you catch issues early.</p>
        </div>
        <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
          <p class="text-sm text-gray-500">[Screenshot: Aftercare email sequence]</p>
        </div>
      </div>

      <div class="grid gap-8 md:grid-cols-2 items-center">
        <div class="order-2 md:order-1 rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
          <p class="text-sm text-gray-500">[Screenshot: Healed photo request]</p>
        </div>
        <div class="order-1 md:order-2">
          <h2 class="text-2xl font-bold text-white">Healed Photo Requests</h2>
          <p class="mt-4 text-gray-400">Request healed photos automatically at 4 weeks. Build your portfolio with real healed work — the most powerful marketing asset for any tattoo artist.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 text-center border-t border-ink-800/50">
    <h2 class="text-2xl font-bold text-white">Automate Your Aftercare</h2>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free</a>
  </section>

  <Footer />
</BaseLayout>
