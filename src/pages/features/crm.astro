---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import StudioHealthQuiz from '../../components/StudioHealthQuiz.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo CRM Software — Client Management for Studios | InkFlow" description="Tattoo client management software with 360° client history, smart segmentation, referral tracking, and automated follow-ups. Stop using spreadsheets. Start free." />
  <Navbar />

  <!-- HERO -->
  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <p class="text-sm font-semibold text-accent-400 mb-3">TATTOO CRM SOFTWARE</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Stop Losing Clients to a Spreadsheet</h1>
      <p class="mt-6 text-lg text-gray-400">Every client who walks through your door has a story — past work, preferences, health history. InkFlow's tattoo CRM keeps it all in one place, so you never ask "have you been here before?" again.</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="https://app.ink-flows.com/register" class="inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
        <a href="/pricing" class="inline-block rounded-lg border border-ink-700 px-8 py-3.5 text-base font-semibold text-white hover:bg-ink-800 transition-all">See Plans</a>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        <div><p class="text-3xl font-bold text-accent-400">360°</p><p class="mt-1 text-sm text-gray-500">Client view — history, photos, payments</p></div>
        <div><p class="text-3xl font-bold text-accent-400">5+ yrs</p><p class="mt-1 text-sm text-gray-500">Client history retention</p></div>
        <div><p class="text-3xl font-bold text-accent-400">Auto</p><p class="mt-1 text-sm text-gray-500">Follow-up reminders & re-engagement</p></div>
        <div><p class="text-3xl font-bold text-accent-400">Smart</p><p class="mt-1 text-sm text-gray-500">Tags & segmentation for targeting</p></div>
      </div>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Why a CRM Matters for Tattoo Studios</h2>
      <div class="mt-8 space-y-4">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><p class="text-gray-400"><strong class="text-white">📝 "Didn't you get a tattoo here last year?"</strong> — Without a CRM, every visit starts from zero. With InkFlow, you see full history the moment a client books.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><p class="text-gray-400"><strong class="text-white">📊 "Who are my most valuable clients?"</strong> — Spreadsheets can't tell you. InkFlow tracks visit frequency, spend, and referrals automatically.</p></div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5"><p class="text-gray-400"><strong class="text-white">📱 "I haven't seen that client in 6 months"</strong> — Automated re-engagement brings lapsed clients back. No manual follow-ups needed.</p></div>
      </div>
    </div>
  </section>

  <!-- FEATURES -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">Everything You Need to Know Your Clients</h2>
      <div class="mt-12 space-y-12">
        <div class="grid gap-8 md:grid-cols-2 items-center">
          <div>
            <h3 class="text-2xl font-bold text-white">360° Client History</h3>
            <p class="mt-4 text-gray-400">Every appointment, waiver, photo, and payment — linked to the client profile. Search by name, phone, or email. See past tattoos, preferences, and medical history instantly.</p>
          </div>
          <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
            <p class="text-sm text-gray-500">[Screenshot: Client profile]</p>
          </div>
        </div>

        <div class="grid gap-8 md:grid-cols-2 items-center">
          <div class="order-2 md:order-1 rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
            <p class="text-sm text-gray-500">[Screenshot: Tags and filters]</p>
          </div>
          <div class="order-1 md:order-2">
            <h3 class="text-2xl font-bold text-white">Smart Tags & Segmentation</h3>
            <p class="mt-4 text-gray-400">Tag clients by style, frequency, or value. Filter and message specific groups — send a flash sale to everyone who loves traditional work, or a re-engagement campaign to lapsed clients.</p>
          </div>
        </div>

        <div class="grid gap-8 md:grid-cols-2 items-center">
          <div>
            <h3 class="text-2xl font-bold text-white">Referral Tracking</h3>
            <p class="mt-4 text-gray-400">See which clients refer the most business. Reward your best advocates automatically. Referral clients convert at higher rates — track the full chain.</p>
          </div>
          <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-8 text-center">
            <p class="text-sm text-gray-500">[Screenshot: Referral stats]</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMPARISON -->
  <section class="border-t border-ink-800/50 py-16 bg-ink-900/20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white text-center">How InkFlow CRM Compares</h2>
      <div class="mt-8 space-y-3">
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">Versus HubSpot/Salesforce → Built for tattoo studios</p><p class="text-sm text-gray-400">General CRMs need heavy customization. InkFlow understands tattoo workflows out of the box.</p></div></div>
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">Versus Booksy/Vagaro → Full history, not just booking data</p><p class="text-sm text-gray-400">Those platforms track appointments. InkFlow tracks everything — waivers, photos, payments, referrals.</p></div></div>
        <div class="flex items-start gap-3"><div class="mt-1 flex h-6 w-6 items-center justify-center rounded-full bg-accent-500/20"><span class="text-sm text-accent-400">✓</span></div><div><p class="text-white font-medium">Versus Google Sheets → Automated, not manual</p><p class="text-sm text-gray-400">Spreadsheets work until you have 100+ clients. InkFlow auto-updates with every booking and payment.</p></div></div>
      </div>
    </div>
  </section>

  <!-- CHECKLIST -->
  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-2xl font-bold text-white">What to Look For in Tattoo CRM Software</h2>
      <ul class="space-y-3 text-gray-400">
        <li class="flex items-start gap-2"><span class="mt-1 text-accent-400">✓</span> <strong class="text-white">Integrated with booking</strong> — CRM should auto-populate from appointments</li>
        <li class="flex items-start gap-2"><span class="mt-1 text-accent-400">✓</span> <strong class="text-white">Photo storage</strong> — Before/after photos linked to each client</li>
        <li class="flex items-start gap-2"><span class="mt-1 text-accent-400">✓</span> <strong class="text-white">Smart segmentation</strong> — Filter by style, frequency, value</li>
        <li class="flex items-start gap-2"><span class="mt-1 text-accent-400">✓</span> <strong class="text-white">Automated follow-ups</strong> — Re-engage lapsed clients without manual work</li>
        <li class="flex items-start gap-2"><span class="mt-1 text-accent-400">✓</span> <strong class="text-white">Referral tracking</strong> — Know who brings in new business</li>
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-ink-800/50 py-16 text-center">
    <h2 class="text-2xl font-bold text-white">Know Every Client. Never Use a Spreadsheet Again.</h2>
    <a href="https://app.ink-flows.com/register" class="mt-6 inline-block rounded-lg bg-accent-500 px-8 py-3.5 text-base font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
  </section>
  <Footer />
</BaseLayout>
