---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const { cities } = await import('../../lib/cities.js');
  return cities.map(city => ({
    params: { city: city.slug },
    props: { city },
  }));
}

const { city } = Astro.props;

const cityName = city.name;
const stateName = city.state;
const shops = city.shops;
const shopCount = shops.length;
const avgRating = shops.length > 0
  ? (shops.reduce((sum, s) => sum + s.rating, 0) / shops.length).toFixed(1)
  : '—';

const pageTitle = `Book a Tattoo in ${cityName}, ${stateName} — InkFlow`;
const pageDesc = `Find the best tattoo shops in ${cityName}, ${stateName}. Browse ${shopCount} studios with ratings, reviews, and maps. Book your appointment online.`;
const h1Text = `Tattoo Booking in ${cityName}, ${stateName}`;
---

<BaseLayout>
  <head>
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
    <link rel="canonical" href={`https://ink-flows.com/book/${city.slug}`} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ItemList",
      "name": `Tattoo Shops in ${cityName}`,
      "itemListElement": shops.map((s, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "item": {
          "@type": "LocalBusiness",
          "name": s.name,
          "aggregateRating": { "@type": "AggregateRating", "ratingValue": s.rating, "reviewCount": s.reviews },
          "address": { "@type": "PostalAddress", "streetAddress": s.address }
        }
      }))
    })} />
  </head>

  <Navbar />

  <!-- Hero -->
  <section class="bg-gradient-to-b from-accent-500/5 to-transparent pt-28 pb-12 sm:pt-36">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">{h1Text}</h1>
      <p class="mt-3 text-lg text-gray-400">{shopCount} studios · Avg {avgRating}/5 rating</p>
      <div class="mt-4 flex flex-wrap items-center justify-center gap-3 text-sm text-gray-500">
        <span>✓ Verified listings</span>
        <span class="text-gray-700">·</span>
        <span>✓ Real customer reviews</span>
        <span class="text-gray-700">·</span>
        <span>✓ Direct booking available</span>
      </div>
    </div>
  </section>

  <!-- Shops List -->
  <section class="py-10">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-2xl font-bold text-white">Tattoo Studios in {cityName}</h2>
      <div class="grid gap-4 md:grid-cols-2">
        {shops.map(shop => (
          <div class="rounded-xl border border-ink-800 bg-ink-900/50 p-5 hover:border-accent-500/30 transition-all">
            <div class="flex items-start justify-between">
              <div>
                <h3 class="text-lg font-bold text-white">{shop.name}</h3>
                <p class="mt-1 text-sm text-gray-400">{shop.address}</p>
                <p class="mt-1 text-sm text-gray-400">{shop.phone}</p>
              </div>
              <div class="text-right">
                <p class="text-lg font-bold text-accent-400">{shop.rating}</p>
                <p class="text-xs text-gray-500">{shop.reviews} reviews</p>
              </div>
            </div>
            <div class="mt-4 flex gap-2">
              <span class="rounded-full border border-ink-700 px-3 py-1 text-xs text-gray-400">Call</span>
              <span class="rounded-full border border-ink-700 px-3 py-1 text-xs text-gray-400">Directions</span>
              {shop.phone && <span class="rounded-full border border-accent-500/30 bg-accent-500/5 px-3 py-1 text-xs text-accent-400">Book Inquiry</span>}
            </div>
          </div>
        ))}
      </div>
      {shops.length === 0 && (
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-8 text-center">
          <p class="text-gray-400">No tattoo shops listed yet in {cityName}.</p>
          <p class="mt-2 text-sm text-gray-500">We're adding new cities regularly. Check back soon.</p>
        </div>
      )}
    </div>
  </section>

  <!-- Nearby -->
  {city.nearby && city.nearby.length > 0 && (
    <section class="border-t border-ink-800/50 py-10">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <h2 class="mb-2 text-2xl font-bold text-white">Nearby Tattoo Studios</h2>
        <p class="mb-6 text-sm text-gray-400">If you don't find what you need in {cityName}, here are options in nearby cities.</p>
        <div class="grid gap-4 md:grid-cols-2">
          {city.nearby.map(shop => (
            <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-4">
              <div class="flex items-start justify-between">
                <div>
                  <p class="font-semibold text-white">{shop.name}</p>
                  <p class="text-sm text-gray-400">{shop.address}</p>
                  <p class="text-xs text-gray-500">{shop.dist} away</p>
                </div>
                <div class="text-right">
                  <p class="text-lg font-bold text-accent-400">{shop.rating}</p>
                  <p class="text-xs text-gray-500">{shop.reviews} reviews</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Map -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-4 text-2xl font-bold text-white">Tattoo Shops in {cityName} — Map</h2>
      <div class="h-[400px] w-full overflow-hidden rounded-xl border border-ink-700 bg-ink-900">
        <iframe
          src={`https://www.google.com/maps?q=tattoo+shop+${encodeURIComponent(cityName + ', ' + stateName)}&output=embed`}
          class="h-full w-full"
          style="border:0"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>

  <!-- Aftercare Affiliate -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-2 text-2xl font-bold text-white">Tattoo Aftercare Products</h2>
      <p class="mb-6 text-sm text-gray-400">Keep your new tattoo looking fresh with these recommended aftercare products.</p>
      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5 text-center hover:border-accent-500/30 transition-all">
          <p class="text-lg font-semibold text-white">Mad Rabbit Balm</p>
          <p class="mt-1 text-sm text-gray-400">Natural tattoo aftercare</p>
          <p class="mt-1 text-sm text-accent-400">$14.99</p>
          <a href="#" class="mt-3 inline-block rounded-lg bg-accent-500 px-4 py-1.5 text-xs font-semibold text-ink-950 hover:bg-accent-400">Shop Now</a>
        </div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5 text-center hover:border-accent-500/30 transition-all">
          <p class="text-lg font-semibold text-white">Hustle Butter</p>
          <p class="mt-1 text-sm text-gray-400">Premium tattoo butter</p>
          <p class="mt-1 text-sm text-accent-400">$19.99</p>
          <a href="#" class="mt-3 inline-block rounded-lg bg-accent-500 px-4 py-1.5 text-xs font-semibold text-ink-950 hover:bg-accent-400">Shop Now</a>
        </div>
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-5 text-center hover:border-accent-500/30 transition-all">
          <p class="text-lg font-semibold text-white">Tattoo Goo</p>
          <p class="mt-1 text-sm text-gray-400">Classic aftercare ointment</p>
          <p class="mt-1 text-sm text-accent-400">$12.99</p>
          <a href="#" class="mt-3 inline-block rounded-lg bg-accent-500 px-4 py-1.5 text-xs font-semibold text-ink-950 hover:bg-accent-400">Shop Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="mb-6 text-center text-2xl font-bold text-white">Tattoo Questions in {cityName}</h2>
      <div class="space-y-4">
        <details class="group rounded-xl border border-ink-800 p-5 open:border-accent-500/30">
          <summary class="flex cursor-pointer items-center justify-between text-sm font-medium text-white">
            How much does a tattoo cost in {cityName}?
            <svg class="h-4 w-4 shrink-0 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-sm text-gray-400">Tattoo prices in {cityName} typically range from $80-$200 per hour depending on the artist's experience and studio location. Small designs start around $100, while larger pieces can cost $500-$3,000+. Most studios offer free consultations for custom work.</p>
        </details>
        <details class="group rounded-xl border border-ink-800 p-5 open:border-accent-500/30">
          <summary class="flex cursor-pointer items-center justify-between text-sm font-medium text-white">
            What are the best tattoo shops in {cityName}?
            <svg class="h-4 w-4 shrink-0 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-sm text-gray-400">Based on customer reviews, the top-rated tattoo studios in {cityName} include {shops.slice(0,3).map(s => s.name).join(', ') || 'several talented artists'}. We recommend checking their portfolios and reading recent reviews before booking.</p>
        </details>
        <details class="group rounded-xl border border-ink-800 p-5 open:border-accent-500/30">
          <summary class="flex cursor-pointer items-center justify-between text-sm font-medium text-white">
            How do I book a tattoo appointment in {cityName}?
            <svg class="h-4 w-4 shrink-0 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-sm text-gray-400">Most {cityName} tattoo studios accept online booking through their websites or social media. We recommend calling ahead or sending a DM on Instagram. Many studios require a deposit to secure your appointment, typically $50-$100 depending on the size of your tattoo.</p>
        </details>
        <details class="group rounded-xl border border-ink-800 p-5 open:border-accent-500/30">
          <summary class="flex cursor-pointer items-center justify-between text-sm font-medium text-white">
            Do tattoo shops in {cityName} require ID?
            <svg class="h-4 w-4 shrink-0 text-gray-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <p class="mt-3 text-sm text-gray-400">Yes, all licensed tattoo studios in {cityName} require valid government-issued photo ID. You must be 18 or older to get a tattoo in Texas. Some studios also accept passports as ID.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Utility Pages -->
  <section class="border-t border-ink-800/50 py-10">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-6 text-center">
        <h2 class="text-xl font-bold text-white">Are You a Tattoo Artist in {cityName}?</h2>
        <p class="mt-2 text-sm text-gray-400">Get listed on this page and receive direct booking inquiries.</p>
        <a href="https://app.ink-flows.com/register" class="mt-4 inline-block rounded-lg bg-accent-500 px-6 py-2.5 text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-all">
          List Your Studio Free
        </a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
