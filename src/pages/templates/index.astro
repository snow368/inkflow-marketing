---

<BaseLayout>
  <SEOHead slot="head" title="101 Tattoo Website Templates — InkFlow" description="Browse 101 tattoo studio website templates. Preview live, pick colors, then publish." />
  <Navbar />

  <section class="pt-24 pb-6 sm:pt-32">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">TEMPLATES</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">101 Templates</h1>
      <p class="mt-3 text-lg text-gray-400">Click any template to preview it live with your chosen colors.</p>
    </div>
  </section>

  <!-- Main preview area (appears when template selected) -->
  <div id="mainPreview" class="hidden border-t border-ink-800/50 py-8">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center gap-4 mb-4">
        <h2 class="text-xl font-bold text-white" id="selName">—</h2>
        <span class="text-sm text-gray-500" id="selMeta"></span>
        <div class="flex gap-2 ml-auto" id="colorDots"></div>
      </div>
      <div class="rounded-xl border border-ink-700 overflow-hidden bg-ink-900/50">
        <iframe id="bigPreview" class="w-full h-[450px]" style="pointer-events:none;border:none;"></iframe>
      </div>
      <div class="max-w-md mx-auto mt-6 text-center">
        <p class="text-gray-400 text-sm mb-3" id="formHint">Enter your details to get a free preview.</p>
        <div id="formFields" class="text-left space-y-3">
          <input type="email" id="fEmail" placeholder="Email *" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm outline-none focus:border-accent-500">
          <input type="text" id="fName" placeholder="Studio Name *" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm outline-none focus:border-accent-500">
          <input type="text" id="fIG" placeholder="Instagram (optional)" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm">
          <button onclick="genSite()" id="genBtn" class="w-full py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400">Generate Free Preview →</button>
        </div>
        <div id="pubResult" class="hidden space-y-3">
          <iframe id="genFrame" class="w-full h-[500px] rounded-xl border border-ink-700" style="pointer-events:none"></iframe>
          <div class="flex gap-3 justify-center">
            <button onclick="pub('basic')" class="px-6 py-3 rounded-lg bg-accent-500 text-white font-semibold">Basic $9.99/yr</button>
            <button onclick="pub('pro')" class="px-6 py-3 rounded-lg bg-green-600 text-white font-semibold">Pro $19.99/yr</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Template Grid -->
  <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 pb-12">
    {LG.map(g => {
      const gs = T.filter(x => x.l === g.k);
      return (
      <div class="mb-10">
        <div class="flex items-center gap-2 mb-4 sticky top-16 z-10 bg-ink-950 py-2">
          <span class="text-xl">{g.i}</span>
          <h2 class="text-lg font-bold text-white">{g.n}</h2>
          <span class="text-xs text-gray-500">({gs.length})</span>
        </div>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3">
          {gs.map(t => (
            <div class="group cursor-pointer rounded-xl border border-ink-800 bg-ink-900/30 overflow-hidden hover:border-accent-500/50 hover:bg-ink-800/50 transition-all"
              onclick={`pickTemplate('${t.k}','${t.n}','${t.t}','${t.l}','${t.a}')`}
              data-key={t.k}>
              <!-- Mini preview thumbnail -->
              <div class="h-28 bg-ink-800/50 overflow-hidden">
                <iframe src={`https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/${t.k}`} class="w-full h-[200px]" loading="lazy" style="pointer-events:none;border:none;transform:scale(0.5);transform-origin:0 0;width:200%;height:400px;"></iframe>
              </div>
              <div class="px-3 py-2 flex items-center gap-2">
                <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style={`background:${t.a}`}></span>
                <p class="text-xs font-medium text-white truncate flex-1">{t.n}</p>
                {t.t !== 'free' && <span class="text-[9px] font-medium" style={`color:${t.t === 'plus' ? '#f59e0b' : '#a33a3a'}`}>{t.t === 'pro' ? 'Pro' : '+'}</span>}
              </div>
            </div>
          ))}
        </div>
      </div>
      );
    })}
  </div>

  <Footer />
</BaseLayout>

<script is:inline>
const PAL = {PAL_JSON};
const ALL = {T_JSON};
let sk='', sn='', st='free', sl='', ca='';

window.pickTemplate = function(k,n,t,l,a) {
  sk=k; sn=n; st=t; sl=l; ca=a;
  document.getElementById('mainPreview').classList.remove('hidden');
  document.getElementById('selName').textContent = n;
  document.getElementById('selMeta').textContent = l + ' · ' + t;
  const cols = PAL[l] || [a];
  document.getElementById('colorDots').innerHTML = cols.map(c =>
    `<button class="cd" style="background:${c};width:28px;height:28px;border-radius:50%;border:2px solid ${c===a?'#fff':'transparent'};cursor:pointer" onclick="pk('${c}')"></button>`
  ).join('');
  updatePreview(k,a);
  document.getElementById('mainPreview').scrollIntoView({behavior:'smooth'});
};

window.pk = function(c) {
  ca=c;
  document.querySelectorAll('.cd').forEach(b => b.style.borderColor = b.style.background === c ? '#fff' : 'transparent');
  updatePreview(sk,c);
};

function updatePreview(k,c) {
  const u = new URL('https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/'+k);
  if(c) u.searchParams.set('accent',c);
  document.getElementById('bigPreview').src = u.toString();
}

async function genSite() {
  const em = document.getElementById('fEmail').value.trim();
  const nm = document.getElementById('fName').value.trim();
  if(!em||!nm) {alert('Email and Studio Name required');return;}
  if(!sk) {alert('Select a template first');return;}
  const btn = document.getElementById('genBtn'); btn.disabled=true; btn.textContent='Generating...';
  try {
    const r = await fetch('https://ink-flow-api.snow368.workers.dev/api/auth/register', {
      method:'POST', headers:{'Content-Type':'application/json'},
      body: JSON.stringify({email:em, name:nm, studioName:nm, plan:st==='free'?'website_basic':'website_pro'})
    });
    const d = await r.json();
    if(!r.ok) {alert('Error: '+(d.error||'Failed')); btn.disabled=false; btn.textContent='Generate Free Preview →'; return;}
    document.getElementById('genFrame').src = 'https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/'+sk+'?accent='+ca;
    document.getElementById('formFields').classList.add('hidden');
    document.getElementById('pubResult').classList.remove('hidden');
  } catch(e) {alert('Network error'); btn.disabled=false; btn.textContent='Generate Free Preview →';}
}

function pub(p) { window.open('https://app.ink-flows.com/register?plan=website_' + p + '&template=' + sk + '&accent=' + ca, '_blank'); }
</script>
