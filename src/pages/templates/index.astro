  { name: 'Archive', key: 'archive', tier: 'free', layout: 'full-experience', accent: '#4a5a6a' },
];
const LAYOUTS = ['classic','hero-grid','link-bio','studio-roster','cards','split','editorial','minimal-bar','gallery-focus','mobile-first','social-proof','process-funnel','full-experience'];
const GNAME = {classic:'Classic Scroll','hero-grid':'Gallery Grid','link-bio':'Link in Bio','studio-roster':'Artist Roster',cards:'Card Style',split:'Split Screen',editorial:'Magazine','minimal-bar':'Sticky Bar','gallery-focus':'Gallery Focus','mobile-first':'Mobile First','social-proof':'Social Proof','process-funnel':'Process Funnel','full-experience':'Full Experience'};
const GICON = {classic:'📜','hero-grid':'🖼️','link-bio':'🔗','studio-roster':'👥',cards:'🃏',split:'↔️',editorial:'📰','minimal-bar':'📱','gallery-focus':'🖼️','mobile-first':'📱','social-proof':'⭐','process-funnel':'🔄','full-experience':'🌟'};
const PAL = {classic:['#1a1a1a','#8b4513','#b8860b','#c4783a','#ff6688'],'hero-grid':['#d4a574','#2a8a8a','#2a7aaa','#e88d9a','#8a6aca'],'link-bio':['#ffffff','#d4d4d4','#ffee00','#cc2222','#666666'],'studio-roster':['#c41e1e','#4a8c3f','#cc9a4a','#5a9e6a','#ff7744'],cards:['#ff0066','#00ffff','#9a9aaa','#ff00aa','#ff66cc'],split:['#7c3aed','#4a80d0','#c8a040','#ff6622','#c4956a'],editorial:['#800020','#cc3300','#b8862a','#ff2244','#ff6600'],'minimal-bar':['#4682b4','#ff6600','#e86a8a','#c0392b','#cc2244'],'gallery-focus':['#c0262d','#1a1a2e','#a67c52','#2a7a9a','#c49a6a'],'mobile-first':['#0099ff','#ff4488','#8a7a5a','#aaff00','#ff6b6b'],'social-proof':['#7a2a2a','#c89a40','#9a1a1a','#1a4a7a','#ff4488'],'process-funnel':['#cc2200','#9a1a1a','#2a8a3a','#cc4400','#aa2222'],'full-experience':['#6a5a4a','#2a2a2a','#c89a3a','#c89aaa','#4a4a4a']};
---

<BaseLayout>
  <SEOHead slot="head" title="101 Tattoo Website Templates — InkFlow" />
  <Navbar />
  <section class="pt-24 pb-6 sm:pt-32">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-2">TEMPLATES</p>
      <h1 class="text-3xl font-extrabold text-white sm:text-4xl">101 Tattoo Website Templates</h1>
      <p class="mt-2 text-gray-400">13 layouts — pick a template, choose your colors, preview live below.</p>
    </div>
  </section>

  {LAYOUTS.map(gk => {
    const gs = TEMPLATES.filter(t => t.layout === gk);
    return (
    <div class="mb-8">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-2 mb-3 sticky top-16 z-10 bg-ink-950 py-2 border-b border-ink-800/50">
          <span>{GICON[gk]}</span>
          <h2 class="text-lg font-bold text-white">{GNAME[gk]}</h2>
          <span class="text-xs text-gray-500">({gs.length})</span>
        </div>
        <div class="rounded-xl border border-ink-700 bg-ink-900/50 overflow-hidden mb-4">
          <div class="h-48 sm:h-64 bg-ink-800/50 flex items-center justify-center">
            <iframe src={`https://ink-flow-api.snow368.workers.dev/api/template-preview/${gs[0].key}`} class="w-full h-full" loading="lazy" title={`${GNAME[gk]} preview`} style="border:none;" />
          </div>
        </div>
        <div class="flex flex-wrap gap-2">
          {gs.map(t => (
            <div class="color-swatch group relative flex items-center gap-1.5 rounded-xl border border-ink-700 bg-ink-900/30 px-3 py-2 hover:border-accent-500/50 hover:bg-ink-800/50 transition-all cursor-pointer"
              data-key={t.key} data-tier={t.tier} data-name={t.name} data-layout={t.layout} data-accent={t.accent}
              style={`border-color: ${t.tier === 'plus' ? '#f59e0b40' : t.tier === 'pro' ? '#a33a3a40' : '#22c55e40'}`}>
              <p class="text-sm font-medium text-white group-hover:text-accent-400 transition-colors whitespace-nowrap">{t.name}</p>
              {t.tier !== 'free' && <span class="text-[10px] font-medium" style={`color: ${t.tier === 'plus' ? '#f59e0b' : '#a33a3a'}`}>{t.tier === 'pro' ? 'Pro' : '+'}</span>}
            </div>
          ))}
        </div>
      </div>
    </div>
    );
  })}

  <section class="border-t border-ink-800/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div id="previewWrap" class="hidden">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-4 h-4 rounded-full" id="dot"></span>
          <h2 class="text-xl font-bold text-white" id="tName"></h2>
          <span class="text-sm text-gray-500" id="tMeta"></span>
        </div>
        <p class="text-sm text-gray-400 mb-3">Pick an accent color:</p>
        <div class="flex gap-2 mb-4" id="colors"></div>
        <div class="rounded-xl border border-ink-700 overflow-hidden mb-6" style="position:relative">
          <iframe id="pv" class="w-full h-72 sm:h-96" style="border:none;"></iframe>
          <div id="pvOverlay" style="position:absolute;inset:0;pointer-events:none;opacity:0;transition:opacity .3s;border-radius:inherit;"></div>
        </div>
      </div>
      <div class="max-w-md mx-auto text-center">
        <h2 class="text-xl font-bold text-white mb-2">Create Your Site</h2>
        <p class="text-gray-400 text-sm mb-4" id="hint">Select a template, pick a color, fill in your info.</p>
        <div id="fields" class="text-left space-y-3">
          <input type="email" id="em" placeholder="Email *" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm">
          <input type="text" id="nm" placeholder="Studio Name *" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm">
          <input type="text" id="ig" placeholder="Instagram (optional)" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm">
          <button onclick="genSite()" class="w-full py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400">Generate Free Preview →</button>
        </div>
        <div id="pres" class="hidden text-left">
          <iframe id="pf" class="w-full h-[450px] rounded-xl border border-ink-700" style="pointer-events:none"></iframe>
          <div class="mt-4 flex gap-3 justify-center">
            <button onclick="pub('basic')" class="px-6 py-3 rounded-lg bg-accent-500 text-white font-semibold">Basic $9.99/yr</button>
            <button onclick="pub('pro')" class="px-6 py-3 rounded-lg bg-green-600 text-white font-semibold">Pro $19.99/yr</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline data-cfasync="false">
var PALETTES = {"classic":["#1a1a1a","#8b4513","#b8860b","#c4783a","#ff6688"],"hero-grid":["#d4a574","#2a8a8a","#2a7aaa","#e88d9a","#8a6aca"],"link-bio":["#ffffff","#d4d4d4","#ffee00","#cc2222","#666666"],"studio-roster":["#c41e1e","#4a8c3f","#cc9a4a","#5a9e6a","#ff7744"],cards:["#ff0066","#00ffff","#9a9aaa","#ff00aa","#ff66cc"],split:["#7c3aed","#4a80d0","#c8a040","#ff6622","#c4956a"],editorial:["#800020","#cc3300","#b8862a","#ff2244","#ff6600"],"minimal-bar":["#4682b4","#ff6600","#e86a8a","#c0392b","#cc2244"],"gallery-focus":["#c0262d","#1a1a2e","#a67c52","#2a7a9a","#c49a6a"],"mobile-first":["#0099ff","#ff4488","#8a7a5a","#aaff00","#ff6b6b"],"social-proof":["#7a2a2a","#c89a40","#9a1a1a","#1a4a7a","#ff4488"],"process-funnel":["#cc2200","#9a1a1a","#2a8a3a","#cc4400","#aa2222"],"full-experience":["#6a5a4a","#2a2a2a","#c89a3a","#c89aaa","#4a4a4a"]};
var selectedKey = '', curColor = '';

// Event delegation for template chips
document.addEventListener('click', function(e) {
  var chip = e.target.closest('.color-swatch');
  if (!chip) return;
  var key = chip.dataset.key, name = chip.dataset.name, tier = chip.dataset.tier, layout = chip.dataset.layout, accent = chip.dataset.accent;
  selectedKey = key; curColor = accent || '#06b6d4';

  // Highlight chip
  document.querySelectorAll('.color-swatch').forEach(function(el) { el.style.borderColor = ''; el.style.background = ''; });
  chip.style.borderColor = '#06b6d4'; chip.style.background = '#06b6d415';

  // Show preview + color picker
  document.getElementById('previewWrap').style.display = 'block';
  document.getElementById('tName').textContent = name;
  document.getElementById('tMeta').textContent = (GNAME[layout] || layout) + ' · ' + tier;
  document.getElementById('dot').style.background = curColor;
  var pal = PALETTES[layout] || [accent];
  document.getElementById('colors').innerHTML = pal.map(function(c) {
    return '<button class="cw" style="background:' + c + ';width:32px;height:32px;border-radius:50%;border:2px solid ' + (c === curColor ? '#fff' : 'transparent') + ';cursor:pointer;margin-right:6px" data-c="' + c + '"></button>';
  }).join('');
  // Attach color click
  document.querySelectorAll('.cw').forEach(function(btn) {
    btn.onclick = function() {
      curColor = this.dataset.c;
      document.getElementById('dot').style.background = curColor;
      document.querySelectorAll('.cw').forEach(function(b) { b.style.borderColor = b.dataset.c === curColor ? '#fff' : 'transparent'; });
      // Overlay tint for background color change
      var ov = document.getElementById('pvOverlay');
      ov.style.opacity = '0.2';
      ov.style.background = curColor;
      document.getElementById('pv').src = 'https://ink-flow-api.snow368.workers.dev/api/template-preview/' + selectedKey + '?accent=' + encodeURIComponent(curColor) + '&_t=' + Date.now();
    };
  });
  // Initial preview with default accent, reset overlay
  var ov = document.getElementById('pvOverlay');
  ov.style.opacity = '0.2';
  ov.style.background = accent;
  document.getElementById('pv').src = 'https://ink-flow-api.snow368.workers.dev/api/template-preview/' + key + '?accent=' + encodeURIComponent(accent) + '&_t=' + Date.now();
});

// Generate preview (no registration)
window.genSite = function() {
  var em = document.getElementById('em').value.trim();
  var nm = document.getElementById('nm').value.trim();
  if (!em || !nm) { alert('Email and Studio Name required'); return; }
  if (!selectedKey) { alert('Select a template first'); return; }
  document.getElementById('pf').src = 'https://ink-flow-api.snow368.workers.dev/api/template-preview/' + selectedKey + '?accent=' + encodeURIComponent(curColor);
  document.getElementById('fields').style.display = 'none';
  document.getElementById('pres').style.display = 'block';
};

window.pub = function(p) {
  window.open('https://app.ink-flows.com/register?plan=website_' + p + '&template=' + selectedKey + '&accent=' + encodeURIComponent(curColor), '_blank');
};
</script>
