---

<BaseLayout>
  <SEOHead slot="head" title="101 Tattoo Website Templates — InkFlow" description="Choose from 101 tattoo studio website templates across 13 unique layouts. Mobile-friendly, SEO-optimized, ready in minutes." />
  <Navbar />

  <section class="pt-24 pb-12 sm:pt-32">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">TEMPLATES</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">13 Layouts · 101 Templates</h1>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">Choose a layout style, then pick your template. Every combination is mobile-friendly, SEO-optimized, and ready in minutes.</p>
    </div>
  </section>

  {LAYOUT_GROUPS.map(group => {
    const groupTemplates = TEMPLATES.filter(t => t.layout === group.key);
    return (
    <section class="border-t border-ink-800/50 py-16">
      <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
        <div class="flex items-start gap-4 mb-8">
          <span class="text-3xl">{group.icon}</span>
          <div>
            <h2 class="text-2xl font-bold text-white">{group.name}</h2>
            <p class="text-sm text-gray-400 mt-1">{group.desc}</p>
          </div>
        </div>

        <!-- Layout preview card (big) -->
        <div class="rounded-xl border border-ink-700 bg-ink-900/50 overflow-hidden mb-6">
          <div class="h-64 sm:h-96 bg-ink-800/50 flex items-center justify-center">
            <iframe src={`https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/${groupTemplates[0].key}`} class="w-full h-full" loading="lazy" title={`${group.name} preview`} style="pointer-events:none;border:none;" />
          </div>
        </div>

        <!-- Template names row (compact chips) -->
        <div class="flex flex-wrap gap-2">
          {groupTemplates.map(t => (
            <div class="color-swatch group relative flex items-center gap-1.5 rounded-xl border border-ink-700 bg-ink-900/30 px-3 py-2 hover:border-accent-500/50 hover:bg-ink-800/50 transition-all cursor-pointer" data-key={t.key} data-tier={t.tier} data-name={t.name} data-layout={t.layout} data-accent={t.accent} style={`border-color: ${t.tier === 'plus' ? '#f59e0b40' : t.tier === 'pro' ? '#a33a3a40' : '#22c55e40'}`}>
              <p class="text-sm font-medium text-white group-hover:text-accent-400 transition-colors whitespace-nowrap">{t.name}</p>
              {t.tier !== 'free' && <span class="text-[10px] font-medium" style={`color: ${t.tier === 'plus' ? '#f59e0b' : '#a33a3a'}`}>{t.tier === 'pro' ? 'Pro' : '+'}</span>}
            </div>
          ))}
        </div>
      </div>
    </section>
    );
  })}

  <!-- Get Started Form -->
  <section class="border-t border-ink-800/50 py-16" id="get-started">
    <div class="mx-auto max-w-2xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-white sm:text-3xl">Create Your Website</h2>
      <p class="mt-3 text-gray-400">Fill in your info. We'll generate your site instantly. Pay only when you're happy.</p>
      <div id="selectedTemplate" class="mt-4 text-sm text-accent-400"></div>

      <!-- Step 1: Info Form -->
      <div id="stepForm" class="mt-8 max-w-md mx-auto text-left">
        <div class="space-y-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1">Email</label>
            <input type="email" id="fieldEmail" placeholder="your@email.com" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Studio Name</label>
            <input type="text" id="fieldName" placeholder="Your Tattoo Studio" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Instagram Handle (optional)</label>
            <input type="text" id="fieldIG" placeholder="@yourstudio" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Bio (optional)</label>
            <textarea id="fieldBio" rows="2" placeholder="Tell clients about your studio..." class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none"></textarea>
          </div>
          <button onclick="generateSite()" id="generateBtn" class="w-full py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400 transition-colors">Generate Free Preview →</button>
          <p class="text-xs text-gray-600 text-center" id="pricingHint">Free preview. Basic ($9.99/yr) gets all free templates. Pro ($19.99/yr) unlocks all 101.</p>
        </div>
      </div>

      <!-- Step 2: Preview -->
      <div id="stepPreview" class="mt-8 hidden">
        <div class="rounded-xl border border-ink-700 overflow-hidden">
          <iframe id="previewFrame" class="w-full h-[500px]" style="pointer-events:none"></iframe>
        </div>
        <div class="mt-6 flex gap-4 justify-center">
          <button onclick="publishSite()" class="px-8 py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400 transition-colors">Publish — $9.99/yr</button>
          <button onclick="publishSitePro()" class="px-8 py-3 rounded-lg bg-green-600 text-white font-semibold hover:bg-green-500 transition-colors">Publish Pro — $19.99/yr</button>
        </div>
        <p class="mt-3 text-xs text-gray-600">Secure payment via Stripe · Cancel anytime</p>
      </div>
    </div>
  </section>

  <!-- Preview + Color Picker -->
  <section class="border-t border-ink-800/50 py-12" id="colorPreview" style="display:none">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="flex items-center gap-3 mb-4">
        <span class="w-4 h-4 rounded-full" id="selectedDot"></span>
        <h2 class="text-xl font-bold text-white" id="selectedNameDisplay"></h2>
        <span class="text-sm text-gray-500" id="selectedMeta"></span>
      </div>
      <p class="text-sm text-gray-400 mb-3">Pick an accent color:</p>
      <div class="flex gap-2 mb-4" id="colorDots"></div>
      <div class="rounded-xl border border-ink-700 overflow-hidden mb-6">
        <iframe id="previewFrame" class="w-full h-72 sm:h-96" style="pointer-events:none;border:none;"></iframe>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  let selectedTemplate = null;
  let selectedTier = 'free';
  let curColor = '';
  const PALETTES = {'classic':['#1a1a1a','#8b4513','#b8860b','#c4783a','#ff6688'],'hero-grid':['#d4a574','#2a8a8a','#2a7aaa','#e88d9a','#8a6aca'],'link-bio':['#ffffff','#d4d4d4','#ffee00','#cc2222','#666666'],'studio-roster':['#c41e1e','#4a8c3f','#cc9a4a','#5a9e6a','#ff7744'],cards:['#ff0066','#00ffff','#9a9aaa','#ff00aa','#ff66cc'],split:['#7c3aed','#4a80d0','#c8a040','#ff6622','#c4956a'],editorial:['#800020','#cc3300','#b8862a','#ff2244','#ff6600'],'minimal-bar':['#4682b4','#ff6600','#e86a8a','#c0392b','#cc2244'],'gallery-focus':['#c0262d','#1a1a2e','#a67c52','#2a7a9a','#c49a6a'],'mobile-first':['#0099ff','#ff4488','#8a7a5a','#aaff00','#ff6b6b'],'social-proof':['#7a2a2a','#c89a40','#9a1a1a','#1a4a7a','#ff4488'],'process-funnel':['#cc2200','#9a1a1a','#2a8a3a','#cc4400','#aa2222'],'full-experience':['#6a5a4a','#2a2a2a','#c89a3a','#c89aaa','#4a4a4a']};

  window.selectTemplate = function(key, name, tier, layout, accent) {
    selectedTemplate = key;
    selectedTier = tier || 'free';
    curColor = accent || '#06b6d4';
    document.getElementById('selectedTemplate').textContent = '✓ Selected: ' + name;

    document.querySelectorAll('.color-swatch').forEach(el => {
      el.style.borderColor = '';
      el.style.background = '';
    });
    const swatch = document.querySelector(`.color-swatch[data-key="${key}"]`);
    if (swatch) {
      swatch.style.borderColor = '#06b6d4';
      swatch.style.background = '#06b6d415';
    }

    // Show color picker + preview
    document.getElementById('colorPreview').style.display = 'block';
    document.getElementById('selectedNameDisplay').textContent = name;
    document.getElementById('selectedMeta').textContent = (layout || '') + ' · ' + (tier || 'free');
    document.getElementById('selectedDot').style.background = curColor;

    // Build color palette
    const pal = PALETTES[layout] || [accent];
    let html = '';
    for (var i = 0; i < pal.length; i++) {
      html += '<button class="color-opt" style="background:' + pal[i] + ';width:32px;height:32px;border-radius:50%;border:2px solid ' + (pal[i] === curColor ? '#fff' : 'transparent') + ';cursor:pointer;margin-right:8px" data-c="' + pal[i] + '"></button>';
    }
    document.getElementById('colorDots').innerHTML = html;

    // Update preview
    updatePreview(key, curColor);

    document.getElementById('colorPreview').scrollIntoView({ behavior: 'smooth' });
  };

  function updatePreview(key, color) {
    var url = 'https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/' + key;
    if (color) url += '?accent=' + encodeURIComponent(color);
    document.getElementById('previewFrame').src = url;
  }

  // Color dot clicks via delegation
  document.addEventListener('click', function(e) {
    var dot = e.target.closest('.color-opt');
    if (dot) {
      curColor = dot.dataset.c;
      document.getElementById('selectedDot').style.background = curColor;
      document.querySelectorAll('.color-opt').forEach(function(b) {
        b.style.borderColor = b.dataset.c === curColor ? '#fff' : 'transparent';
      });
      updatePreview(selectedTemplate, curColor);
      return;
    }

    const swatch = e.target.closest('.color-swatch');
    if (swatch) {
      const key = swatch.dataset.key;
      const name = swatch.dataset.name;
      const tier = swatch.dataset.tier;
      const layout = swatch.dataset.layout;
      const accent = swatch.dataset.accent;
      window.selectTemplate(key, name, tier, layout, accent);
    }
  });

  async function generateSite() {
    const email = document.getElementById('fieldEmail').value.trim();
    const name = document.getElementById('fieldName').value.trim();
    if (!email || !name) { alert('Email and Studio Name are required'); return; }
    if (!selectedTemplate) { alert('Please select a template first'); return; }

    const btn = document.getElementById('generateBtn');
    btn.disabled = true; btn.textContent = 'Generating Preview...';

    // Just generate a preview — no registration needed
    document.getElementById('previewFrame').src = 'https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/' + selectedTemplate + '?accent=' + curColor;

    document.getElementById('stepForm').classList.add('hidden');
    document.getElementById('stepPreview').classList.remove('hidden');
    btn.disabled = false; btn.textContent = 'Generate Free Preview →';
  }
    btn.disabled = true; btn.textContent = 'Generating...';

    try {
      const res = await fetch('https://ink-flow-api.snow368.workers.dev/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, name, studioName: name, plan: selectedTier === 'free' ? 'website_basic' : 'website_pro' })
      });
      const data = await res.json();
      if (!res.ok) { alert('Error: ' + (data.error || 'Registration failed')); btn.disabled = false; btn.textContent = 'Generate Free Preview →'; return; }

      const previewUrl = 'https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/' + selectedTemplate;
      document.getElementById('previewFrame').src = previewUrl;
      document.getElementById('stepForm').classList.add('hidden');
      document.getElementById('stepPreview').classList.remove('hidden');
    } catch (e) {
      alert('Network error. Please try again.');
      btn.disabled = false; btn.textContent = 'Generate Free Preview →';
    }
  }

  function publishSite() {
    window.open('https://app.ink-flows.com/register?plan=website_basic&template=' + selectedTemplate, '_blank');
  }

  function publishSitePro() {
    window.open('https://app.ink-flows.com/register?plan=website_pro&template=' + selectedTemplate, '_blank');
  }
</script>
