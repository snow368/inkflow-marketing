  { name: 'Gallery', key: 'gallery', tier: 'pro', layout: 'full-experience', accent: '#2a2a2a' },
  { name: 'Collection', key: 'collection', tier: 'free', layout: 'full-experience', accent: '#c89a3a' },
  { name: 'Anthology', key: 'anthology', tier: 'pro', layout: 'full-experience', accent: '#c89aaa' },
  { name: 'Monograph', key: 'monograph', tier: 'plus', layout: 'full-experience', accent: '#4a4a4a' },
  { name: 'Portfolio', key: 'portfolio', tier: 'free', layout: 'full-experience', accent: '#6a2a2a' },
  { name: 'Retrospective', key: 'retrospective', tier: 'pro', layout: 'full-experience', accent: '#6a2a1a' },
  { name: 'Showcase', key: 'showcase', tier: 'free', layout: 'full-experience', accent: '#2a8a8a' },
  { name: 'Compilation', key: 'compilation', tier: 'free', layout: 'full-experience', accent: '#b8702a' },
  { name: 'Treasury', key: 'treasury', tier: 'plus', layout: 'full-experience', accent: '#c49a3a' },
