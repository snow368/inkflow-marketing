const GROUP_NAMES = { classic: 'Classic Scroll', 'hero-grid': 'Gallery Grid', 'link-bio': 'Link in Bio', 'studio-roster': 'Artist Roster', cards: 'Card Style', split: 'Split Screen', editorial: 'Magazine', 'minimal-bar': 'Sticky Bar', 'gallery-focus': 'Gallery Focus', 'mobile-first': 'Mobile First', 'social-proof': 'Social Proof', 'process-funnel': 'Process Funnel', 'full-experience': 'Full Experience' };
const GROUP_ICONS = { classic: '📜', 'hero-grid': '🖼️', 'link-bio': '🔗', 'studio-roster': '👥', cards: '🃏', split: '↔️', editorial: '📰', 'minimal-bar': '📱', 'gallery-focus': '🖼️', 'mobile-first': '📱', 'social-proof': '⭐', 'process-funnel': '🔄', 'full-experience': '🌟' };
const PALETTES = { classic: ['#1a1a1a','#8b4513','#b8860b','#c4783a','#ff6688'], 'hero-grid': ['#d4a574','#2a8a8a','#2a7aaa','#e88d9a','#8a6aca'], 'link-bio': ['#ffffff','#d4d4d4','#ffee00','#cc2222','#666666'], 'studio-roster': ['#c41e1e','#4a8c3f','#cc9a4a','#5a9e6a','#ff7744'], cards: ['#ff0066','#00ffff','#9a9aaa','#ff00aa','#ff66cc'], split: ['#7c3aed','#4a80d0','#c8a040','#ff6622','#c4956a'], editorial: ['#800020','#cc3300','#b8862a','#ff2244','#ff6600'], 'minimal-bar': ['#4682b4','#ff6600','#e86a8a','#c0392b','#cc2244'], 'gallery-focus': ['#c0262d','#1a1a2e','#a67c52','#2a7a9a','#c49a6a'], 'mobile-first': ['#0099ff','#ff4488','#8a7a5a','#aaff00','#ff6b6b'], 'social-proof': ['#7a2a2a','#c89a40','#9a1a1a','#1a4a7a','#ff4488'], 'process-funnel': ['#cc2200','#9a1a1a','#2a8a3a','#cc4400','#aa2222'], 'full-experience': ['#6a5a4a','#2a2a2a','#c89a3a','#c89aaa','#4a4a4a'] };
const GROUPS = Object.keys(GROUP_NAMES);
---

<BaseLayout>
  <SEOHead slot="head" title="101 Tattoo Website Templates — InkFlow" description="Browse 101 tattoo studio templates. Choose your layout, pick colors, preview instantly." />
  <Navbar />

  <section class="pt-24 pb-6 sm:pt-32">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-2">TEMPLATES</p>
      <h1 class="text-3xl font-extrabold text-white sm:text-4xl">101 Tattoo Website Templates</h1>
      <p class="mt-2 text-gray-400">13 layouts — pick a template, choose your colors, preview live below.</p>
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-4">
    {GROUPS.map(gkey => {
      const gtemps = TEMPLATES.filter(t => t.layout === gkey);
      return (
      <div class="mb-8">
        <div class="flex items-center gap-2 mb-3 sticky top-16 z-10 bg-ink-950 py-2 border-b border-ink-800/50">
          <span>{GROUP_ICONS[gkey]}</span>
          <h2 class="text-lg font-bold text-white">{GROUP_NAMES[gkey]}</h2>
          <span class="text-xs text-gray-500">({gtemps.length})</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {gtemps.map(t => (
            <div class="group relative flex items-center gap-1.5 rounded-xl border border-ink-700 bg-ink-900/30 px-3 py-2 hover:border-accent-500/50 hover:bg-ink-800/50 transition-all cursor-pointer"
              data-key={t.key}
              onclick={`pick('${t.key}','${t.name}','${t.tier}','${t.layout}')`}>
              <span class="w-2.5 h-2.5 rounded-full" style={`background:${t.accent}`}></span>
              <span class="text-sm font-medium text-white whitespace-nowrap">{t.name}</span>
              {t.tier !== 'free' && <span class="text-[9px] font-medium" style={`color:${t.tier === 'plus' ? '#f59e0b' : '#a33a3a'}`}>{t.tier === 'pro' ? 'Pro' : '+'}</span>}
            </div>
          ))}
        </div>
      </div>
      );
    })}
  </div>

  <!-- Preview + Color + Form Area -->
  <section class="border-t border-ink-800/50 py-10">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div id="previewWrap" class="hidden">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-4 h-4 rounded-full" id="dot"></span>
          <h2 class="text-xl font-bold text-white" id="tName">—</h2>
          <span class="text-sm text-gray-500" id="tMeta"></span>
        </div>
        <p class="text-sm text-gray-400 mb-3">Choose accent color:</p>
        <div class="flex gap-2 mb-4" id="colors"></div>
        <div class="rounded-xl border border-ink-700 overflow-hidden mb-6">
          <iframe id="pv" class="w-full h-72 sm:h-96" style="pointer-events:none;border:none;"></iframe>
        </div>
      </div>

      <div class="max-w-md mx-auto text-center" id="formSec">
        <h2 class="text-xl font-bold text-white mb-2">Create Your Site</h2>
        <p class="text-gray-400 text-sm mb-4" id="hint">Select a template above, pick a color, then fill this in.</p>
        <div id="fields" class="text-left space-y-3">
          <input type="email" id="em" placeholder="Email *" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm">
          <input type="text" id="nm" placeholder="Studio Name *" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm">
          <input type="text" id="ig" placeholder="Instagram (optional)" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm">
          <button onclick="gen()" id="gb" class="w-full py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400">Generate Free Preview →</button>
        </div>
        <div id="pres" class="hidden text-left">
          <iframe id="pf" class="w-full h-[450px] rounded-xl border border-ink-700" style="pointer-events:none"></iframe>
          <div class="mt-4 flex gap-3 justify-center">
            <button onclick="pub('basic')" class="px-6 py-3 rounded-lg bg-accent-500 text-white font-semibold">Basic $9.99/yr</button>
            <button onclick="pub('pro')" class="px-6 py-3 rounded-lg bg-green-600 text-white font-semibold">Pro $19.99/yr</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline define:vars={{ PALETTES, TEMPLATES, GROUP_NAMES, GROUP_ICONS }}>
const P = PALETTES;
const A = TEMPLATES;
const GN = GROUP_NAMES;
const GI = GROUP_ICONS;
let k='',n='',ti='free',ly='',cc='';

window.pick=function(key,name,tier,layout) {
  k=key;n=name;ti=tier;ly=layout;
  const t=A.find(x=>x.key===key);
  cc=t?.accent||'#06b6d4';
  document.getElementById('previewWrap').classList.remove('hidden');
  document.getElementById('tName').textContent=name;
  document.getElementById('tMeta').textContent=GN[layout]+' · '+tier;
  document.getElementById('dot').style.background=cc;
  const pal=P[layout]||[cc];
  document.getElementById('colors').innerHTML=pal.map(c=>
    `<button class="sw" style="background:${c};width:32px;height:32px;border-radius:50%;border:2px solid ${c===cc?'#fff':'transparent'};cursor:pointer" onclick="swatch('${c}')"></button>`
  ).join('');
  upv(key,cc);
};

window.swatch=function(c){cc=c;document.getElementById('dot').style.background=c;document.querySelectorAll('.sw').forEach(b=>b.style.borderColor=b.style.background===c?'#fff':'transparent');upv(k,c);};

function upv(key,c){const u=new URL('https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/'+key);if(c)u.searchParams.set('accent',c);document.getElementById('pv').src=u.toString();}

async function gen(){
  const em=document.getElementById('em').value.trim(),nm=document.getElementById('nm').value.trim();
  if(!em||!nm){alert('Email and Studio Name required');return;}
  if(!k){alert('Select a template first');return;}
  const btn=document.getElementById('gb');btn.disabled=true;btn.textContent='Generating...';
  try{
    const r=await fetch('https://ink-flow-api.snow368.workers.dev/api/auth/register',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({email:em,name:nm,studioName:nm,plan:ti==='free'?'website_basic':'website_pro'})});
    const d=await r.json();
    if(!r.ok){alert('Error: '+(d.error||'Failed'));btn.disabled=false;btn.textContent='Generate Free Preview →';return;}
    document.getElementById('pf').src='https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/'+k+'?accent='+cc;
    document.getElementById('fields').classList.add('hidden');document.getElementById('pres').classList.remove('hidden');
  }catch(e){alert('Network error');btn.disabled=false;btn.textContent='Generate Free Preview →';}
}
function pub(p){window.open('https://app.ink-flows.com/register?plan=website_'+p+'&template='+k+'&accent='+cc,'_blank');}
</script>
