const LAYOUT_GROUPS = [
  { key: 'classic', name: 'Classic Scroll', icon: '📜', desc: 'Full single-page scrolling — hero, services, gallery, map.' },
  { key: 'hero-grid', name: 'Gallery Grid', icon: '🖼️', desc: 'Full-screen hero with masonry photo grid.' },
