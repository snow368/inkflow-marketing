---

<BaseLayout>
  <SEOHead slot="head" title="101 Tattoo Website Templates — InkFlow" description="Choose from 101 tattoo studio website templates across 13 unique layouts. Pick a template, customize the colors, preview instantly." />
  <Navbar />

  <section class="pt-24 pb-8 sm:pt-32">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">TEMPLATES</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">13 Layouts · 101 Templates</h1>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">Choose a layout, pick a template, customize the accent color, then preview live below.</p>
    </div>
  </section>

  <!-- All layout groups visible, no folding -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-4">
    {LAYOUT_GROUPS.map((group) => {
      const gtemps = TEMPLATES.filter(t => t.layout === group.key);
      return (
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xl">{group.icon}</span>
          <h2 class="text-lg font-bold text-white">{group.name}</h2>
          <span class="text-xs text-gray-500">({gtemps.length})</span>
        </div>
        <div class="flex flex-wrap gap-2">
          {gtemps.map(t => (
            <div class="template-chip group relative flex items-center gap-1.5 rounded-xl border border-ink-700 bg-ink-900/30 px-3 py-2 hover:border-accent-500/50 hover:bg-ink-800/50 transition-all cursor-pointer"
              data-key={t.key}
              onclick={`selectTemplate('${t.key}', '${t.name}', '${t.tier}', '${t.layout}')`}>
              <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style={`background:${t.accent}`}></span>
              <p class="text-sm font-medium text-white whitespace-nowrap">{t.name}</p>
              {t.tier !== 'free' && <span class="text-[10px] font-medium" style={`color:${t.tier === 'plus' ? '#f59e0b' : '#a33a3a'}`}>{t.tier === 'pro' ? 'Pro' : '+'}</span>}
            </div>
          ))}
        </div>
      </div>
      );
    })}
  </div>

  <!-- Color Picker & Preview -->
  <section class="border-t border-ink-800/50 py-12" id="previewArea">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div id="selectedInfo" class="hidden mb-8">
        <div class="flex items-center gap-3 mb-4">
          <span class="w-4 h-4 rounded-full" id="selectedColorDot"></span>
          <h2 class="text-2xl font-bold text-white" id="selectedName">—</h2>
          <span class="text-sm text-gray-500" id="selectedLayout"></span>
        </div>
        <p class="text-sm text-gray-400 mb-3">Pick an accent color:</p>
        <div class="flex flex-wrap gap-3 mb-6" id="colorPalette"></div>
        <div class="rounded-xl border border-ink-700 overflow-hidden bg-ink-900/50">
          <iframe id="previewFrame" class="w-full h-64 sm:h-96" style="pointer-events:none;border:none;" loading="lazy"></iframe>
        </div>
      </div>

      <!-- Form -->
      <div id="formArea" class="max-w-md mx-auto text-center mt-8">
        <h2 class="text-2xl font-bold text-white sm:text-3xl mb-2">Create Your Website</h2>
        <p class="text-gray-400 mb-6" id="formHint">Select a template above, pick colors, then fill in your details.</p>
        <div id="formFields" class="text-left space-y-4">
          <input type="email" id="fieldEmail" placeholder="Email *" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm outline-none focus:border-accent-500">
          <input type="text" id="fieldName" placeholder="Studio Name *" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm outline-none focus:border-accent-500">
          <input type="text" id="fieldIG" placeholder="Instagram (optional)" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm outline-none focus:border-accent-500">
          <textarea id="fieldBio" rows="2" placeholder="Bio (optional)" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm outline-none focus:border-accent-500"></textarea>
          <button onclick="generateSite()" id="genBtn" class="w-full py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400">Generate Free Preview →</button>
          <p class="text-xs text-gray-600 text-center">Basic $9.99/yr (free templates) · Pro $19.99/yr (all 101)</p>
        </div>
        <div id="previewResult" class="hidden text-left">
          <iframe id="genPreview" class="w-full h-[500px] rounded-xl border border-ink-700" style="pointer-events:none"></iframe>
          <div class="mt-6 flex gap-4 justify-center">
            <button onclick="pubBasic()" class="px-8 py-3 rounded-lg bg-accent-500 text-white font-semibold">Publish Basic — $9.99/yr</button>
            <button onclick="pubPro()" class="px-8 py-3 rounded-lg bg-green-600 text-white font-semibold">Publish Pro — $19.99/yr</button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  let selKey = '', selName = '', selTier = 'free', selLayout = '', curColor = '';

  const PAL = <JSON.stringify(COLOR_PALETTES) />;
  const MAP = <JSON.stringify(Object.fromEntries(TEMPLATES.map(t => [t.key, t]))) />;

  window.selectTemplate = function(key, name, tier, layout) {
    selKey = key; selName = name; selTier = tier; selLayout = layout;
    curColor = MAP[key]?.accent || '#06b6d4';
    document.querySelectorAll('.template-chip').forEach(e => { e.style.borderColor = ''; e.style.background = ''; });
    const ch = document.querySelector(`.template-chip[data-key="${CSS.escape(key)}"]`);
    if (ch) { ch.style.borderColor = '#06b6d4'; ch.style.background = '#06b6d415'; }
    document.getElementById('selectedInfo').classList.remove('hidden');
    document.getElementById('selectedName').textContent = name;
    document.getElementById('selectedLayout').textContent = layout + ' · ' + tier;
    document.getElementById('selectedColorDot').style.background = curColor;
    const pal = PAL[layout] || [curColor];
    document.getElementById('colorPalette').innerHTML = pal.map(c =>
      `<button class="cw" style="background:${c};width:2.5rem;height:2.5rem;border-radius:9999px;border:2px solid ${c === curColor ? '#fff' : 'transparent'};cursor:pointer;transition:all .15s" onclick="pickColor('${c}')"></button>`
    ).join('');
    updatePreview(key, curColor);
    document.getElementById('previewArea').scrollIntoView({behavior:'smooth'});
  };

  window.pickColor = function(c) {
    curColor = c;
    document.getElementById('selectedColorDot').style.background = c;
    document.querySelectorAll('.cw').forEach(b => b.style.borderColor = b.style.background === c ? '#fff' : 'transparent');
    updatePreview(selKey, c);
  };

  function updatePreview(key, accent) {
    const u = new URL('https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/' + key);
    if (accent) u.searchParams.set('accent', accent);
    document.getElementById('previewFrame').src = u.toString();
  }

  async function generateSite() {
    const email = document.getElementById('fieldEmail').value.trim();
    const name = document.getElementById('fieldName').value.trim();
    if (!email || !name) { alert('Email and Studio Name are required'); return; }
    if (!selKey) { alert('Please select a template first'); return; }
    const btn = document.getElementById('genBtn'); btn.disabled = true; btn.textContent = 'Generating...';
    try {
      const r = await fetch('https://ink-flow-api.snow368.workers.dev/api/auth/register', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ email, name, studioName: name, plan: selTier === 'free' ? 'website_basic' : 'website_pro' })
      });
      const d = await r.json();
      if (!r.ok) { alert('Error: ' + (d.error||'Registration failed')); btn.disabled = false; btn.textContent = 'Generate Free Preview →'; return; }
      document.getElementById('genPreview').src = 'https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/' + selKey + '?accent=' + curColor;
      document.getElementById('formFields').classList.add('hidden');
      document.getElementById('previewResult').classList.remove('hidden');
    } catch(e) { alert('Network error'); btn.disabled = false; btn.textContent = 'Generate Free Preview →'; }
  }

  function pubBasic() { window.open('https://app.ink-flows.com/register?plan=website_basic&template=' + selKey + '&accent=' + curColor, '_blank'); }
  function pubPro() { window.open('https://app.ink-flows.com/register?plan=website_pro&template=' + selKey + '&accent=' + curColor, '_blank'); }
</script>
