---

<BaseLayout>
  <SEOHead slot="head" title="101 Tattoo Website Templates — InkFlow" description="Choose from 101 tattoo studio website templates across 13 unique layouts. Pick a template, customize the colors, preview instantly." />
  <Navbar />

  <section class="pt-24 pb-8 sm:pt-32">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm font-semibold text-accent-400 mb-3">TEMPLATES</p>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">13 Layouts · 101 Templates</h1>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">Pick a layout → choose a template → customize your colors → see a live preview.</p>
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-8" id="templateAccordion">
    {LAYOUT_GROUPS.map((group, gi) => {
      const groupTemplates = TEMPLATES.filter(t => t.layout === group.key);
      const isFirst = gi === 0;
      return (
      <div class="border border-ink-800/50 rounded-xl mb-3 overflow-hidden" data-group={group.key}>
        <button class="accordion-header w-full flex items-center gap-3 px-5 py-4 bg-ink-900/50 hover:bg-ink-800/50 transition-colors text-left" onclick="toggleAccordion('{group.key}')">
          <span class="text-2xl">{group.icon}</span>
          <div class="flex-1">
            <span class="font-bold text-white text-lg">{group.name}</span>
            <span class="text-sm text-gray-500 ml-2">({groupTemplates.length})</span>
          </div>
          <span class="text-gray-500 text-sm" id="arrow-{group.key}">{isFirst ? '▼' : '▶'}</span>
        </button>
        <div class={`${isFirst ? '' : 'hidden'}`} id="content-{group.key}">
          <div class="p-5 pt-3">
            <p class="text-sm text-gray-400 mb-4">{group.desc}</p>
            <div class="flex flex-wrap gap-2 mb-4">
              {groupTemplates.map(t => (
                <div class="template-chip group relative flex items-center gap-2 rounded-xl border border-ink-700 bg-ink-900/30 px-3 py-2 hover:border-accent-500/50 hover:bg-ink-800/50 transition-all cursor-pointer"
                  data-key={t.key} data-tier={t.tier} data-layout={t.layout} data-accent={t.accent}
                  onclick="selectTemplate('{t.key}', '{t.name}', '{t.tier}', '{t.layout}')">
                  <span class="w-3 h-3 rounded-full flex-shrink-0" style="background:{t.accent}"></span>
                  <p class="text-sm font-medium text-white group-hover:text-accent-400 transition-colors whitespace-nowrap">{t.name}</p>
                  {t.tier !== 'free' && <span class="text-[10px] font-medium px-1 py-0.5 rounded" style={`color: ${t.tier === 'plus' ? '#f59e0b' : '#a33a3a'}; background: ${t.tier === 'plus' ? '#f59e0b15' : '#a33a3a15'}`}>{t.tier === 'pro' ? 'PRO' : 'PLUS'}</span>}
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
      );
    })}
  </div>

  <section class="border-t border-ink-800/50 py-12" id="previewArea">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div id="selectedInfo" class="hidden mb-8">
        <div class="flex items-center gap-3 mb-6">
          <span class="w-4 h-4 rounded-full" id="selectedColorDot"></span>
          <h2 class="text-2xl font-bold text-white" id="selectedName">—</h2>
          <span class="text-sm text-gray-500" id="selectedLayout"></span>
        </div>
        <p class="text-sm text-gray-400 mb-3">Choose your accent color:</p>
        <div class="flex flex-wrap gap-3 mb-6" id="colorPalette"></div>
        <div class="rounded-xl border border-ink-700 overflow-hidden bg-ink-900/50 mb-6">
          <div class="h-64 sm:h-96 bg-ink-800/50 flex items-center justify-center">
            <iframe id="previewFrame" class="w-full h-full" style="pointer-events:none;border:none;" loading="lazy" title="Template preview"></iframe>
          </div>
        </div>
      </div>

      <div id="stepFormSection" class="max-w-md mx-auto text-center">
        <h2 class="text-2xl font-bold text-white sm:text-3xl mb-2">Create Your Website</h2>
        <p class="text-gray-400 mb-6" id="stepHint">Pick a template above, choose colors, then fill in your info.</p>
        <div id="stepForm" class="text-left space-y-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1">Email</label>
            <input type="email" id="fieldEmail" placeholder="your@email.com" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Studio Name</label>
            <input type="text" id="fieldName" placeholder="Your Tattoo Studio" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Instagram Handle <span class="text-gray-600">(optional)</span></label>
            <input type="text" id="fieldIG" placeholder="@yourstudio" class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Bio <span class="text-gray-600">(optional)</span></label>
            <textarea id="fieldBio" rows="2" placeholder="Tell clients about your studio..." class="w-full px-4 py-2.5 rounded-lg border border-ink-700 bg-ink-900 text-white text-sm focus:border-accent-500 outline-none"></textarea>
          </div>
          <button onclick="generateSite()" id="generateBtn" class="w-full py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400 transition-colors disabled:opacity-50">Generate Free Preview →</button>
          <p class="text-xs text-gray-600 text-center">Free preview. Basic ($9.99/yr) gets free templates. Pro ($19.99/yr) unlocks all 101.</p>
        </div>
        <div id="stepPreview" class="hidden text-left">
          <div class="rounded-xl border border-ink-700 overflow-hidden mb-6">
            <iframe id="generatedPreview" class="w-full h-[500px]" style="pointer-events:none"></iframe>
          </div>
          <div class="flex gap-4 justify-center">
            <button onclick="publishSite()" class="px-8 py-3 rounded-lg bg-accent-500 text-white font-semibold hover:bg-accent-400 transition-colors">Publish — $9.99/yr</button>
            <button onclick="publishSitePro()" class="px-8 py-3 rounded-lg bg-green-600 text-white font-semibold hover:bg-green-500 transition-colors">Publish Pro — $19.99/yr</button>
          </div>
          <p class="mt-3 text-xs text-gray-600 text-center">Secure payment via Stripe · Cancel anytime</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script is:inline>
  let selectedKey = null;
  let selectedName = '';
  let selectedTier = 'free';
  let selectedLayout = '';
  let selectedAccent = '';
  let currentColor = '';

  window.toggleAccordion = function(key) {
    const el = document.getElementById('content-' + key);
    const arrow = document.getElementById('arrow-' + key);
    if (!el || !arrow) return;
    const isOpen = !el.classList.contains('hidden');
    el.classList.toggle('hidden');
    arrow.textContent = isOpen ? '▶' : '▼';
  };

  const COLOR_PALETTES = <JSON.stringify(COLOR_PALETTES) />;
  const TEMPLATES_MAP = <JSON.stringify(Object.fromEntries(TEMPLATES.map(t => [t.key, t]))) />;

  window.selectTemplate = function(key, name, tier, layout) {
    selectedKey = key;
    selectedName = name;
    selectedTier = tier || 'free';
    selectedLayout = layout;
    selectedAccent = TEMPLATES_MAP[key]?.accent || '#06b6d4';
    currentColor = selectedAccent;

    document.querySelectorAll('.template-chip').forEach(el => {
      el.style.borderColor = '';
      el.style.background = '';
    });
    const chip = document.querySelector(`.template-chip[data-key="${key}"]`);
    if (chip) {
      chip.style.borderColor = '#06b6d4';
      chip.style.background = '#06b6d415';
    }

    document.getElementById('selectedInfo').classList.remove('hidden');
    document.getElementById('selectedName').textContent = name;
    document.getElementById('selectedLayout').textContent = layout + ' · ' + tier;
    document.getElementById('selectedColorDot').style.background = selectedAccent;

    const pal = COLOR_PALETTES[layout] || [selectedAccent];
    const paletteDiv = document.getElementById('colorPalette');
    paletteDiv.innerHTML = pal.map(c =>
      `<button class="color-opt w-10 h-10 rounded-full border-2 transition-all hover:scale-110 ${c === selectedAccent ? 'border-white scale-110 ring-2 ring-accent-500' : 'border-ink-600'}" style="background:${c}" onclick="pickColor('${c}')" title="${c}"></button>`
    ).join('');

    updatePreview(key, currentColor);
    document.getElementById('previewArea').scrollIntoView({ behavior: 'smooth' });
  };

  window.pickColor = function(color) {
    currentColor = color;
    document.getElementById('selectedColorDot').style.background = color;
    document.querySelectorAll('.color-opt').forEach(el => {
      el.classList.remove('border-white', 'scale-110', 'ring-2', 'ring-accent-500');
      el.classList.add('border-ink-600');
    });
    const btn = document.querySelector(`.color-opt[style*="background: ${color}"]`) ||
                document.querySelector(`.color-opt[style*="background:${color}"]`);
    if (btn) {
      btn.classList.remove('border-ink-600');
      btn.classList.add('border-white', 'scale-110', 'ring-2', 'ring-accent-500');
    }
    updatePreview(selectedKey, color);
  };

  function updatePreview(key, accent) {
    const iframe = document.getElementById('previewFrame');
    const url = new URL('https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/' + key);
    if (accent) url.searchParams.set('accent', accent);
    iframe.src = url.toString();
  }

  async function generateSite() {
    const email = document.getElementById('fieldEmail').value.trim();
    const name = document.getElementById('fieldName').value.trim();
    const ig = document.getElementById('fieldIG').value.trim();
    const bio = document.getElementById('fieldBio').value.trim();
    if (!email || !name) { alert('Email and Studio Name are required'); return; }
    if (!selectedKey) { alert('Please select a template first'); return; }
    const btn = document.getElementById('generateBtn');
    btn.disabled = true; btn.textContent = 'Generating...';
    try {
      const res = await fetch('https://ink-flow-api.snow368.workers.dev/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, name, studioName: name, plan: selectedTier === 'free' ? 'website_basic' : 'website_pro' })
      });
      const data = await res.json();
      if (!res.ok) { alert('Error: ' + (data.error || 'Registration failed')); btn.disabled = false; btn.textContent = 'Generate Free Preview →'; return; }
      const previewUrl = 'https://ink-flow-api.inkflowapp.workers.dev/api/template-preview/' + selectedKey + '?accent=' + currentColor;
      document.getElementById('generatedPreview').src = previewUrl;
      document.getElementById('stepForm').classList.add('hidden');
      document.getElementById('stepPreview').classList.remove('hidden');
      document.getElementById('stepHint').textContent = 'Preview your site below. Happy? Click publish!';
    } catch (e) {
      alert('Network error. Please try again.');
      btn.disabled = false; btn.textContent = 'Generate Free Preview →';
    }
  }

  function publishSite() {
    window.open('https://app.ink-flows.com/register?plan=website_basic&template=' + selectedKey + '&accent=' + currentColor, '_blank');
  }
  function publishSitePro() {
    window.open('https://app.ink-flows.com/register?plan=website_pro&template=' + selectedKey + '&accent=' + currentColor, '_blank');
  }
</script>
