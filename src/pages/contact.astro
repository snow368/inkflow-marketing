---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Contact InkFlow — Get in Touch" description="Questions about InkFlow? Contact us at hello@ink-flows.com. We're here to help your studio." />
  <Navbar />

  <section class="pt-24 pb-20 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Contact Us</h1>
      <p class="mt-4 text-lg text-gray-400">Have a question? We'd love to hear from you.</p>
      <p class="mt-8 text-gray-400">Email: <a href="mailto:hello@ink-flows.com" class="text-accent-400 hover:underline">hello@ink-flows.com</a></p>
    </div>
  </section>
  <Footer />
</BaseLayout>
