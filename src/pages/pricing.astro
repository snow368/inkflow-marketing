          <a href="https://app.ink-flows.com/register" class="mt-8 block w-full rounded-lg border border-ink-700 py-2.5 text-center text-sm font-medium text-gray-300 hover:border-ink-500 hover:text-white transition-colors">Upgrade to Solo</a>
        </div>

        <!-- PRO -->
        <div class="rounded-xl border-2 border-accent-500 bg-ink-900 p-8 relative flex flex-col">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-accent-500 px-4 py-0.5 text-xs font-semibold text-ink-950">Most Popular</span>
          <h2 class="text-lg font-semibold text-white">Pro</h2>
          <p class="mt-2 text-4xl font-bold text-white">$29.99</p>
          <p class="mt-1 text-sm text-gray-400">Per month — 1 shop, up to 5 artists</p>
          <ul class="mt-8 space-y-3 text-sm text-gray-400 flex-1">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Everything in Solo</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Up to 5 artist accounts</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Commission splitting</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Aftercare automation</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Inventory tracking</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Staff management</li>
          </ul>
