---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageSchema from '../components/PageSchema.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="InkFlow Pricing — Free, Solo $9.9, Pro $29.99 | Tattoo Studio Software" description="Free for solo artists. Solo $9.9/mo, Pro $29.99/mo for studios, Plus for multi-location. Start free, upgrade when you grow." />
  <PageSchema type="software" data={{
    description: "Tattoo studio management software. Free forever, Solo $9.9/mo, Pro $29.99/mo, Plus from $29.99/mo.",
    offers: { price: "0", currency: "USD" },
    aggregateRating: { value: "4.8", count: "127" },
  }} />
  <Navbar />

  <!-- HERO -->
  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 text-center">
      <Breadcrumb items={[
        { label: 'Home', href: '/' },
        { label: 'Pricing' },
      ]} />
      <p class="text-sm font-semibold text-accent-400 mb-3">PRICING</p>
      <div class="inline-block rounded-full bg-accent-500/10 border border-accent-500/30 px-4 py-1.5 text-xs text-accent-400 mb-4">🚀 内测期间全部功能免费 · 提建议送3个月Pro</div>
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Free for Solo Artists. Upgrade When You Grow.</h1>
      <p class="mt-4 text-lg text-gray-400 max-w-2xl mx-auto">正式定价如下。内测期间所有功能免费使用。升级到 Solo、Pro 或 Plus 在正式上线后才需要。</p>
    </div>
  </section>

  <!-- PLANS -->
  <section class="pb-20">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-8 md:grid-cols-4 max-w-6xl mx-auto">

        <!-- FREE -->
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-8 flex flex-col">
          <h2 class="text-lg font-semibold text-white">Free</h2>
          <p class="mt-2 text-4xl font-bold text-white">$0</p>
          <p class="mt-1 text-sm text-gray-400">Forever free — basic manual tools</p>
          <ul class="mt-8 space-y-3 text-sm text-gray-400 flex-1">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> 1 artist</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Manual client management</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Manual appointment booking</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Local-only (no cloud sync)</li>
          </ul>
          <a href="https://app.ink-flows.com/register" class="mt-8 block w-full rounded-lg border border-ink-700 py-2.5 text-center text-sm font-medium text-gray-300 hover:border-ink-500 hover:text-white transition-colors">Get Started Free</a>
        </div>

        <!-- SOLO -->
        <div class="rounded-xl border border-ink-800 bg-ink-900/30 p-8 flex flex-col">
          <h2 class="text-lg font-semibold text-white">Solo</h2>
          <p class="mt-2 text-4xl font-bold text-white">$9.9</p>
          <p class="mt-1 text-sm text-gray-400">Per month — 1 artist</p>
          <ul class="mt-8 space-y-3 text-sm text-gray-400 flex-1">
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Online booking widget</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Digital waivers</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Client CRM + cloud sync</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> SMS & email reminders</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Deposit collection</li>
            <li class="flex items-start gap-2"><span class="mt-0.5 text-accent-400">✓</span> Payment links</li>
