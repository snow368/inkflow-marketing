---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Business Software | InkFlow" description="Booking, CRM, payments, inventory, reporting — all in one platform." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Business Management Software</h1>
      <p class="mt-6 text-lg text-gray-400 max-w-2xl mx-auto">Manage your entire studio in one place.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/pricing" class="rounded-lg bg-accent-600 px-6 py-3 text-sm font-semibold text-white hover:bg-accent-500">Start Free Trial</a>
        <a href="/contact" class="rounded-lg border border-ink-700 px-6 py-3 text-sm font-semibold text-gray-300 hover:bg-ink-800">Book a Demo</a>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-8 text-center">Run Your Studio Smarter</h2>
      <div class="grid gap-8 md:grid-cols-3">
                <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-6">
          <h3 class="text-lg font-semibold text-white">Dashboard Overview</h3>
          <p class="mt-3 text-gray-400">Revenue and bookings at a glance.</p>
        </div>
        <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-6">
          <h3 class="text-lg font-semibold text-white">Financial Reports</h3>
          <p class="mt-3 text-gray-400">Revenue per artist and service.</p>
        </div>
        <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-6">
          <h3 class="text-lg font-semibold text-white">Inventory Management</h3>
          <p class="mt-3 text-gray-400">Track supplies. Low stock alerts.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16 bg-ink-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white">Take Control of Your Studio</h2>
      <p class="mt-4 text-lg text-gray-400">Get insights to grow your business.</p>
      <div class="mt-8">
        <a href="/pricing" class="rounded-lg bg-accent-600 px-8 py-4 text-base font-semibold text-white hover:bg-accent-500">Get Started Free</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
