---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo Studio Pro Alternatives — Best Options 2026" description="Looking for Tattoo Studio Pro alternatives? Compare InkFlow vs TSP, Tattoogenda, Booksy. InkFlow includes aftercare automation starting at $0/mo." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo Studio Pro Alternatives</h1>
      <p class="mt-4 text-lg text-gray-400">If Tattoo Studio Pro isn't the right fit, here are the best alternatives for your tattoo studio.</p>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="space-y-8">
        <div class="rounded-xl border border-accent-500/30 bg-accent-500/5 p-6">
          <h2 class="text-xl font-bold text-white">InkFlow</h2>
          <p class="mt-2 text-sm text-gray-400">Best all-in-one alternative with a free plan, aftercare automation, and multi-language support.</p>
          <a href="https://app.ink-flows.com/register" class="mt-3 inline-block text-sm font-medium text-accent-400 hover:underline">Try InkFlow Free →</a>
        </div>
        <div class="rounded-xl border border-ink-800 p-6">
          <h2 class="text-xl font-bold text-white">Tattoogenda</h2>
          <p class="mt-2 text-sm text-gray-400">Good for multi-location studios. Strong booking and CRM features.</p>
        </div>
        <div class="rounded-xl border border-ink-800 p-6">
          <h2 class="text-xl font-bold text-white">Booksy</h2>
          <p class="mt-2 text-sm text-gray-400">Simple booking platform. Works for solo artists but lacks tattoo-specific features.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
