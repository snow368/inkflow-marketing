---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEOHead from '../components/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Tattoo CRM Software" description="Build stronger relationships. Client history, preferences, automated follow-ups, and marketing." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Tattoo CRM Software for Client Relationships</h1>
      <p class="mt-6 text-lg text-gray-400 max-w-2xl mx-auto">Know your clients and what they want next.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-4">
        <a href="/pricing" class="rounded-lg bg-accent-600 px-6 py-3 text-sm font-semibold text-white hover:bg-accent-500">Start Free Trial</a>
        <a href="/contact" class="rounded-lg border border-ink-700 px-6 py-3 text-sm font-semibold text-gray-300 hover:bg-ink-800">Book a Demo</a>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-8 text-center">CRM for Tattoo Studios</h2>
      <div class="grid gap-8 md:grid-cols-3">
                <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-6">
          <h3 class="text-lg font-semibold text-white">Client Profiles</h3>
          <p class="mt-3 text-gray-400">Full history: tattoos, designs, preferences.</p>
        </div>
        <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-6">
          <h3 class="text-lg font-semibold text-white">Automated Follow-Ups</h3>
          <p class="mt-3 text-gray-400">Birthday messages and rebooking prompts.</p>
        </div>
        <div class="rounded-xl bg-ink-900/50 border border-ink-800 p-6">
          <h3 class="text-lg font-semibold text-white">Marketing Tools</h3>
          <p class="mt-3 text-gray-400">Email and SMS campaigns for offers.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16 bg-ink-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white">Turn Clients into Regulars</h2>
      <p class="mt-4 text-lg text-gray-400">Build relationships that keep them coming back.</p>
      <div class="mt-8">
        <a href="/pricing" class="rounded-lg bg-accent-600 px-8 py-4 text-base font-semibold text-white hover:bg-accent-500">Get Started Free</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
