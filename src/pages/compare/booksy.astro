---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="InkFlow vs Booksy — The Full Comparison" description="Compare InkFlow vs Booksy for tattoo studios. See how they stack up on booking, deposits, waivers, commission tracking, pricing, and tattoo-specific features." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">InkFlow vs Booksy for Tattoo Studios</h1>
        <p class="mt-4 text-lg text-gray-400">Booksy is a general booking platform. InkFlow is purpose-built for tattoo studios. Here's how they compare.</p>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="overflow-hidden rounded-xl border border-ink-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-ink-800 bg-ink-900/50">
              <th class="p-4 text-left font-semibold text-white w-1/3">Feature</th>
              <th class="p-4 text-center font-semibold text-accent-400 w-1/3">InkFlow</th>
              <th class="p-4 text-center font-semibold text-gray-400 w-1/3">Booksy</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink-800/50">
            {[
              { f: 'Starting Price', i: '$0/mo (Free plan)', b: '$29.99/mo + $20/additional provider' },
              { f: 'Tattoo-Specific', i: '✅ Built for tattoo studios', b: '⚠️ General salon platform' },
              { f: 'Deposit Collection', i: '✅ At booking (Stripe)', b: '✅ Card-on-file deposits' },
              { f: 'Digital Waivers', i: '✅ Included in all plans', b: '❌ Not available' },
              { f: 'Commission Splitting', i: '✅ Auto-calculated', b: '✅ Manual tracking (Pro)' },
              { f: 'Aftercare Automation', i: '✅ Built-in', b: '❌ Not available' },
              { f: 'Online Booking', i: '✅ Unlimited', b: '✅ Unlimited' },
              { f: 'SMS Reminders', i: '✅ Included', b: '✅ $0.07/SMS extra' },
              { f: 'Client CRM', i: '✅ 360° history + tags', b: '⚠️ Basic profiles' },
              { f: 'Inventory Tracking', i: '✅ Ink, needles, supplies', b: '❌ Not available' },
              { f: 'Payment Processing', i: '2.9% + $0.30', b: '2.49% + $0.10 (card)' },
              { f: 'Free Trial', i: '✅ No credit card', b: '✅ Limited trial' },
              { f: 'Portfolio Gallery', i: '✅ Artist profiles', b: '❌ Not available' },
              { f: 'Gift Cards', i: '✅ Digital & in-person', b: '✅ Available' },
            ].map(row => (
              <tr class="hover:bg-ink-900/30 transition-colors">
                <td class="p-4 text-gray-300 font-medium">{row.f}</td>
                <td class="p-4 text-center text-accent-300">{row.i}</td>
                <td class="p-4 text-center text-gray-500">{row.b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Quick Verdict -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-accent-500/20 bg-accent-500/5 p-8">
        <h2 class="text-xl font-bold text-white">The Bottom Line</h2>
        <p class="mt-4 text-gray-400">
          Booksy works for solo artists who need basic booking and discoverability through their marketplace. But as your studio grows, the cost adds up ($20/additional provider) and you'll miss tattoo-specific features like digital waivers, aftercare automation, and inventory tracking that Booksy doesn't offer at all.
        </p>
        <p class="mt-2 text-gray-400">
          <strong class="text-accent-300">InkFlow</strong> gives you everything a tattoo studio needs — booking, deposits, waivers, CRM, payments, inventory, aftercare — for less than Booksy's base plan. And it's built by people who understand tattoo studios.
        </p>
        <div class="mt-6">
          <a href="https://app.ink-flows.com/register" class="rounded-lg bg-accent-500 px-6 py-3 text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
