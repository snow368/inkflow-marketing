---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="InkFlow vs Vagaro for Tattoo Studios — 2026 Full Comparison" description="Compare InkFlow vs Vagaro for tattoo studios. Vagaro is built for salons — InkFlow is built for tattoo shops. See how they stack up on price and features." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-3xl">
        <h1 class="text-4xl font-extrabold text-white sm:text-5xl">InkFlow vs Vagaro for Tattoo Studios</h1>
        <p class="mt-4 text-lg text-gray-400">Vagaro is a powerful all-in-one platform for salons and spas. But tattoo studios have specific needs that generic platforms don't address well.</p>
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="overflow-hidden rounded-xl border border-ink-800">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-ink-800 bg-ink-900/50">
              <th class="p-4 text-left font-semibold text-white w-1/3">Feature</th>
              <th class="p-4 text-center font-semibold text-accent-400 w-1/3">InkFlow</th>
              <th class="p-4 text-center font-semibold text-gray-400 w-1/3">Vagaro</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink-800/50">
            {[
              { f: 'Starting Price', i: '$0/mo (Free plan)', b: '$23.99/mo (1 calendar)' },
              { f: 'Additional Providers', i: 'Included in plan', b: '$10/user/month' },
              { f: 'Tattoo-Specific', i: '✅ Purpose-built', b: '⚠️ Salon roots' },
              { f: 'Digital Waivers', i: '✅ Included in all plans', b: '❌ +$10/mo add-on' },
              { f: 'Deposit Collection', i: '✅ At booking', b: '✅ Available' },
              { f: 'Commission Splitting', i: '✅ Auto-calculated', b: '✅ Available' },
              { f: 'Aftercare Automation', i: '✅ Built-in', b: '❌ Not available' },
              { f: 'Inventory Tracking', i: '✅ Ink, needles, supplies', b: '✅ Available' },
              { f: 'Client CRM', i: '✅ 360° history + tags', b: '✅ Basic CRM' },
              { f: 'Payment Processing', i: '2.9% + $0.30', b: '2.75% (card-present)' },
              { f: 'POS Hardware', i: '❌ Not needed (links)', b: '✅ PayPro $300+ (terminal)' },
              { f: 'Free Trial', i: '✅ No credit card', b: '✅ Available' },
              { f: 'Portfolio Gallery', i: '✅ Artist profiles', b: '❌ Limited' },
              { f: 'Setup Complexity', i: '✅ 5 minutes', b: '⚠️ Weeks to configure' },
            ].map(row => (
              <tr class="hover:bg-ink-900/30 transition-colors">
                <td class="p-4 text-gray-300 font-medium">{row.f}</td>
                <td class="p-4 text-center text-accent-300">{row.i}</td>
                <td class="p-4 text-center text-gray-500">{row.b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Quick Verdict -->
  <section class="border-t border-ink-800/50 py-12">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="rounded-xl border border-accent-500/20 bg-accent-500/5 p-8">
        <h2 class="text-xl font-bold text-white">The Bottom Line</h2>
        <p class="mt-4 text-gray-400">
          Vagaro is a capable platform — if you run a salon. For tattoo studios, you'll pay extra for waivers ($10/mo), deal with features designed for haircuts and facials, and spend weeks configuring workarounds.
        </p>
        <p class="mt-2 text-gray-400">
          <strong class="text-accent-300">InkFlow</strong> was built from the ground up for tattoo studios. Digital waivers included, commission tracking designed for shop setups, aftercare automation that keeps clients coming back. And it integrates with your existing Stripe account — no extra hardware or contracts.
        </p>
        <div class="mt-6">
          <a href="https://app.ink-flows.com/register" class="rounded-lg bg-accent-500 px-6 py-3 text-sm font-semibold text-ink-950 hover:bg-accent-400 transition-all">Try InkFlow Free →</a>
        </div>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
