---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SEOHead from '../../components/SEOHead.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
---

<BaseLayout>
  <SEOHead slot="head" title="Best Tattoo Studio Software 2026: Complete Comparison | InkFlow" description="Compare the best tattoo studio software platforms. InkFlow vs Booksy vs Vagaro. Features, pricing, and reviews. Find the right fit for your studio." />
  <Navbar />

  <section class="pt-24 pb-16 sm:pt-32">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Best Tattoo Studio Software 2026</h1>
      <p class="mt-6 text-lg text-gray-400 max-w-2xl mx-auto">We compared the top tattoo studio software platforms so you don't have to. Here's what we found.</p>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-white mb-8">Platform Comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-gray-400">
          <thead class="text-left text-xs uppercase text-gray-500">
            <tr class="border-b border-ink-800">
              <th class="pb-4 pr-4 font-medium">Feature</th>
              <th class="pb-4 pr-4 font-medium text-accent-400">InkFlow</th>
              <th class="pb-4 pr-4 font-medium">Booksy</th>
              <th class="pb-4 pr-4 font-medium">Vagaro</th>
              <th class="pb-4 font-medium">Mindbody</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-ink-800/50">
            <tr><td class="py-3 pr-4">Online Booking</td><td class="py-3 pr-4 text-accent-400">Yes</td><td class="py-3 pr-4">Yes</td><td class="py-3 pr-4">Yes</td><td class="py-3">Yes</td></tr>
            <tr><td class="py-3 pr-4">Digital Waivers</td><td class="py-3 pr-4 text-accent-400">Built-in</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4">No</td><td class="py-3">No</td></tr>
            <tr><td class="py-3 pr-4">Client CRM</td><td class="py-3 pr-4 text-accent-400">Built-in</td><td class="py-3 pr-4">Basic</td><td class="py-3 pr-4">Yes</td><td class="py-3">Yes</td></tr>
            <tr><td class="py-3 pr-4">POS System</td><td class="py-3 pr-4 text-accent-400">Built-in</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4">Yes</td><td class="py-3">Yes</td></tr>
            <tr><td class="py-3 pr-4">Commission Tracking</td><td class="py-3 pr-4 text-accent-400">Built-in</td><td class="py-3 pr-4">No</td><td class="py-3 pr-4">Limited</td><td class="py-3">Limited</td></tr>
            <tr><td class="py-3 pr-4">Tattoo-Specific</td><td class="py-3 pr-4 text-accent-400">Yes</td><td class="py-3 pr-4">No (salon)</td><td class="py-3 pr-4">No (salon)</td><td class="py-3">No (wellness)</td></tr>
            <tr><td class="py-3 pr-4">Free Plan</td><td class="py-3 pr-4 text-accent-400">Yes</td><td class="py-3 pr-4">Limited</td><td class="py-3 pr-4">No</td><td class="py-3">No</td></tr>
            <tr><td class="py-3 pr-4">Starting Price</td><td class="py-3 pr-4 text-accent-400">$0/mo</td><td class="py-3 pr-4">$29/mo</td><td class="py-3 pr-4">$35/mo</td><td class="py-3">$59/mo</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="border-t border-ink-800/50 py-16 bg-ink-900/30">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-3xl font-bold text-white">Why InkFlow Is the Best Choice for Tattoo Studios</h2>
      <p class="mt-4 text-lg text-gray-400">Built by tattoo artists, for tattoo artists. Everything you need in one platform — starting free.</p>
      <div class="mt-8">
        <a href="/pricing" class="rounded-lg bg-accent-600 px-8 py-4 text-base font-semibold text-white hover:bg-accent-500">Start Free Trial</a>
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>
