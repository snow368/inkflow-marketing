          <tr><td class="py-2 pr-4 font-semibold">Starting price</td><td class="py-2 pr-4 text-accent-400">$9.99/mo</td><td class="py-2 pr-4">$29/mo</td><td class="py-2 pr-4">Free / $20+</td><td class="py-2 pr-4">Your time</td></tr>
