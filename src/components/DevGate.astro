---
const isDev = import.meta.env.PUBLIC_DEV_MODE === 'true';
---

{
  true ? (
    <slot />
  ) : (
    <div class="flex min-h-screen items-center justify-center bg-ink-950">
      <div class="text-center">
        <div class="mb-4 text-6xl">🚧</div>
        <h1 class="text-2xl font-bold text-white">Coming Soon</h1>
        <p class="mt-2 text-gray-400">InkFlow marketing site is under development.</p>
      </div>
    </div>
  )
}

